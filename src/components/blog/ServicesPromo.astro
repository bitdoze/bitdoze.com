---
interface Props {
  locale?: "en" | "es";
}

const { locale = "en" } = Astro.props;

const copy = locale === "es"
  ? {
      eyebrow: "Servicios Bitdoze",
      title: "Necesitas ayuda con Astro, VPS, Dokploy o una app self-hosted?",
      body: "Si prefieres no pelearte solo con la implementacion, aqui tienes una vista clara de los servicios que ya cubro en el sitio.",
      cta: "Ver servicios",
      href: "/es/services/",
      note: "Trabajo tecnico, no relleno comercial.",
    }
  : {
      eyebrow: "Bitdoze Services",
      title: "Need help with Astro, VPS, Dokploy, or a self-hosted app?",
      body: "If you would rather skip the messy implementation phase, there is now a clear services page built around the same topics already covered on the site.",
      cta: "View Services",
      href: "/services/",
      note: "Technical work, not filler consulting.",
    };
---

<aside
  class="services-promo not-prose my-8"
  data-services-promo
>
  <div class="services-promo__glow"></div>
  <div class="services-promo__inner">
    <div class="services-promo__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 16.5z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5V4a3 3 0 1 1 6 0v1" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12h7" />
      </svg>
    </div>

    <div class="services-promo__content">
      <p class="services-promo__eyebrow">{copy.eyebrow}</p>
      <h2 class="services-promo__title">{copy.title}</h2>
      <p class="services-promo__body">{copy.body}</p>
    </div>

    <div class="services-promo__actions">
      <a href={copy.href} class="services-promo__button">
        {copy.cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <p class="services-promo__note">{copy.note}</p>
    </div>
  </div>
</aside>

<script is:inline>
  (() => {
    const promos = document.querySelectorAll("[data-services-promo]");
    if (!promos.length) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      promos.forEach((promo) => promo.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35 },
    );

    promos.forEach((promo) => observer.observe(promo));
  })();
</script>

<style>
  .services-promo {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(239, 246, 255, 0.96));
    box-shadow:
      0 18px 40px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    opacity: 0.72;
    transform: translateY(18px) scale(0.985);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .services-promo.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .services-promo:hover {
    border-color: rgba(59, 130, 246, 0.35);
    box-shadow:
      0 24px 48px rgba(37, 99, 235, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .services-promo__glow {
    position: absolute;
    right: -2rem;
    top: -2rem;
    height: 9rem;
    width: 9rem;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.2), transparent 70%);
    transition: transform 0.4s ease;
  }

  .services-promo:hover .services-promo__glow {
    transform: scale(1.12);
  }

  .services-promo__inner {
    position: relative;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr;
    padding: 1.1rem 1.15rem;
    align-items: center;
  }

  .services-promo__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: white;
    box-shadow: 0 10px 22px rgba(37, 99, 235, 0.25);
    transition: transform 0.3s ease;
  }

  .services-promo:hover .services-promo__icon {
    transform: translateY(-2px) rotate(-4deg);
  }

  .services-promo__content {
    min-width: 0;
  }

  .services-promo__eyebrow {
    margin: 0 0 0.2rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(37 99 235);
  }

  .services-promo__title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.35;
    color: rgb(15 23 42);
  }

  .services-promo__body {
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgb(71 85 105);
  }

  .services-promo__actions {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    grid-column: 2;
    align-items: flex-start;
  }

  .services-promo__button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border-radius: 9999px;
    background: rgb(15 23 42);
    color: white;
    padding: 0.72rem 1rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.18);
  }

  .services-promo__button:hover {
    transform: translateY(-1px);
    background: rgb(37 99 235);
    box-shadow: 0 16px 28px rgba(37, 99, 235, 0.26);
  }

  .services-promo__note {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgb(100 116 139);
  }

  :global(.dark) .services-promo {
    border-color: rgba(71, 85, 105, 0.55);
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(12, 74, 110, 0.82));
    box-shadow:
      0 20px 40px rgba(2, 6, 23, 0.36),
      inset 0 1px 0 rgba(148, 163, 184, 0.08);
  }

  :global(.dark) .services-promo:hover {
    border-color: rgba(96, 165, 250, 0.45);
    box-shadow:
      0 28px 52px rgba(8, 47, 73, 0.5),
      inset 0 1px 0 rgba(148, 163, 184, 0.12);
  }

  :global(.dark) .services-promo__title {
    color: rgb(241 245 249);
  }

  :global(.dark) .services-promo__body {
    color: rgb(191 219 254);
  }

  :global(.dark) .services-promo__note {
    color: rgb(148 163 184);
  }

  :global(.dark) .services-promo__button {
    background: white;
    color: rgb(15 23 42);
    box-shadow: 0 12px 24px rgba(2, 6, 23, 0.28);
  }

  :global(.dark) .services-promo__button:hover {
    background: rgb(186 230 253);
    box-shadow: 0 16px 32px rgba(14, 116, 144, 0.3);
  }

  @media (min-width: 768px) {
    .services-promo__inner {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 1.1rem 1.25rem;
      padding: 1.2rem 1.3rem;
    }

    .services-promo__actions {
      grid-column: 3;
      justify-self: end;
      align-items: flex-end;
    }

    .services-promo__note {
      text-align: right;
    }
  }
</style>
