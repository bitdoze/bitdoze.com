---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getEntryHref } from "@utils/content";
import { getLocaleFromPathname, isPostIdInLocale } from "@utils/i18n";
import { buildArchivePath, toTaxonomySlug } from "@utils/slugs";
import { formatDate } from "@utils/date";

export interface Props {
  tags?: string[];
  postsPerTag?: number;
}

const { tags = ["docker", "astro", "carrd"], postsPerTag = 5 } = Astro.props;

// Get all posts
const locale = getLocaleFromPathname(Astro.url.pathname);
const popularTopicsLabel = locale === "es" ? "Temas populares" : "Popular Topics";
const viewAllLabel = locale === "es" ? "Ver todos los articulos de" : "View all";
const viewAllSuffix = locale === "es" ? "" : " posts";
const allPosts = await getCollection("posts", ({ id, data }) => {
  return !data.draft && isPostIdInLocale(id, locale);
});

// Sort posts by date (most recent first)
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.date || "");
  const dateB = new Date(b.data.date || "");
  return dateB.getTime() - dateA.getTime();
});

// Get posts for each tag
const tagPosts = tags.map((tag) => ({
  tag,
  posts: sortedPosts
    .filter((post) =>
      post.data.tags?.map((t: string) => toTaxonomySlug(t)).includes(toTaxonomySlug(tag))
    )
    .slice(0, postsPerTag),
}));

---

<section
  class="mt-16 border-y border-gray-200 bg-gray-50 py-14 dark:border-gray-700 dark:bg-gray-800/40"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <h2
          class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white"
        >
          {popularTopicsLabel}
        </h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          {locale === "es" ? "Los temas mas leidos del sitio" : "The stacks readers come here for"}
        </p>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-8 lg:gap-12">
      {
        tagPosts.map(({ tag, posts }) => (
          <div>
            <div class="flex items-center gap-2 border-b-2 border-blue-600 pb-3 dark:border-blue-400">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white capitalize">
                {tag}
              </h3>
              <span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                {posts.length}
              </span>
            </div>
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              {posts.map((post) => {
                const href = getEntryHref(post);

                return (
                <a
                  href={href}
                  class="group flex items-center gap-3 py-3"
                >
                  <div class="relative w-16 shrink-0 overflow-hidden rounded-md border border-gray-200 dark:border-gray-700">
                    <div class="aspect-video">
                      {post.data.image && (
                        <Image
                          src={post.data.image}
                          alt={post.data.title}
                          width={64}
                          height={36}
                          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        />
                      )}
                    </div>
                  </div>
                  <div class="min-w-0 grow">
                    <h4
                      class="line-clamp-2 text-sm font-medium leading-snug text-gray-800 transition-colors duration-200 group-hover:text-blue-600 dark:text-gray-200 dark:group-hover:text-blue-400"
                    >
                      {post.data.title}
                    </h4>
                    {post.data.date && (
                      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                        {formatDate(new Date(post.data.date), locale)}
                      </p>
                    )}
                  </div>
                </a>
                );
              })}
            </div>
            <div class="pt-3">
              <a
                href={buildArchivePath("tags", toTaxonomySlug(tag), locale)}
                class="group inline-flex items-center text-sm font-semibold text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
              >
                <span>{viewAllLabel} {tag}{viewAllSuffix}</span>
                <svg
                  class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
