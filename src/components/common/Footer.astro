---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import menu from "@config/menu.json";
import { getSocialLinks, siteConfig } from "@config/site";
import logoSVG from "@assets/favicons/bitdoze_logo_better.svg";
import { t, translateMenuLabel } from "@i18n/ui";
import { getEntryHref } from "@utils/content";
import { getLocaleFromPathname } from "@utils/i18n";
import { isExternalUrl, localizeInternalPath } from "@utils/localeRoutes";
import { getRecentPosts } from "@utils/recentPosts";

const locale = getLocaleFromPathname(Astro.url.pathname);
const localizeUrl = (url: string): string =>
  !url || isExternalUrl(url) ? url : localizeInternalPath(url, locale);
const footerMenu = menu.footer.map((item) => ({
  ...item,
  name: translateMenuLabel(locale, item.name),
  url: localizeUrl(item.url),
}));

const socialLinks = getSocialLinks();

// Shared build-time cache — one collection scan for all pages
const recentPosts = await getRecentPosts(locale, 3);
---

<footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 mt-10 w-full">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Logo and Description -->
      <div class="flex flex-col space-y-4">
        <a href={locale === "es" ? "/es/" : "/"} class="inline-flex items-center" aria-label="Bitdoze Home">
          <Image
            src={logoSVG}
            alt="Bitdoze Logo"
            width={140}
            height={140}
            class="mr-2"
          />
        </a>
        <p class="text-gray-500 dark:text-gray-400 text-sm">
          {t(locale, "siteTagline")}
        </p>
        <!-- Social Media Links -->
        <div class="flex space-x-4 mt-4">
          {socialLinks.map(({ platform, url }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors duration-300"
              aria-label={`Follow on ${platform}`}
            >
              <Icon name={`mdi:${platform}`} class="w-6 h-6" />
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gray-900 dark:text-white font-semibold text-lg mb-4">
          {t(locale, "quickLinks")}
        </h3>
        <ul class="space-y-2">
          {footerMenu.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors duration-300"
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Latest Posts -->
      <div>
        <h3 class="text-gray-900 dark:text-white font-semibold text-lg mb-4">
          {t(locale, "latestPosts")}
        </h3>
        <div class="space-y-4">
          {
            recentPosts.map((post) => {
              const href = getEntryHref(post);

              return (
              <a
                href={href}
                class="flex gap-3 group items-start"
              >
                <div class="grow">
                  <h4 class="text-sm text-gray-800 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300 line-clamp-2">
                    {post.data.title}
                  </h4>
                </div>
                {post.data.image && (
                  <div class="shrink-0 w-16">
                    <Image
                      src={post.data.image}
                      alt={post.data.title}
                      width={64}
                      height={36}
                      class="rounded w-full aspect-video object-cover"
                    />
                  </div>
                )}
              </a>
              );
            })
          }
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-200 dark:border-gray-700 mt-8 pt-6 text-center space-y-2">
      <p class="text-gray-500 dark:text-gray-400 text-sm">
        &copy; {new Date().getFullYear()} {siteConfig.name}. {t(locale, "allRightsReserved")}
      </p>
      <p class="text-gray-400 dark:text-gray-500 text-xs max-w-2xl mx-auto">
        {
          locale === "es"
            ? "Algunos enlaces son de afiliados. Si compras a través de ellos, podemos recibir una comisión sin coste adicional para ti."
            : "Some links are affiliate links. If you buy through them, we may earn a commission at no extra cost to you."
        }
      </p>
    </div>
  </div>
</footer>
