---
// src/components/YouTubeVideosSSG.astro
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { fetchYouTubeVideos } from "@utils/server/youtube";
import type { YouTubeVideo } from "@utils/server/youtube";
import { getTransitionAnimation } from "@utils/view-transitions";

// Your YouTube Channel ID
const CHANNEL_ID = "UCGsUtKhXsRrMvYAWm8q0bCg"; // Replace with your channel ID
const MAX_VIDEOS = 6; // Number of videos to display

let videos: YouTubeVideo[] = [];
let error = null;

try {
  videos = await fetchYouTubeVideos(CHANNEL_ID, MAX_VIDEOS);
} catch (err) {
  if (import.meta.env.DEV) {
    console.error("Error fetching YouTube videos:", err);
  }
  error = err instanceof Error ? err.message : "An unknown error occurred";
}

const videoTransition = getTransitionAnimation("youtubeVideos");
const videoTitleTransition = getTransitionAnimation("postTitles");
const videoTransitionAttrs = videoTransition
  ? { ["transition:animate"]: videoTransition }
  : {};
const videoTitleTransitionAttrs = videoTitleTransition
  ? { ["transition:animate"]: videoTitleTransition }
  : {};
---

<section class="py-14">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-end justify-between gap-4 mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <div>
        <h2
          class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white"
        >
          Latest YouTube videos
        </h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          The same guides, on video
        </p>
      </div>
      <a
        href={`https://www.youtube.com/channel/${CHANNEL_ID}`}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
      >
        <Icon name="mdi:youtube" class="w-4 h-4" />
        Watch on YouTube
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </div>

    {
      error ? (
        <div class="text-center py-8">
          <p class="text-red-600 dark:text-red-400">
            Unable to load YouTube videos. Please try again later.
          </p>
        </div>
      ) : videos.length === 0 ? (
        <div class="text-center py-8">
          <p class="text-gray-600 dark:text-gray-400">No videos found.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.map((video) => (
            <div class="group overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
              <a
                href={video.url}
                target="_blank"
                rel="noopener noreferrer"
                class="relative block"
              >
                <Image
                  src={video.thumbnail}
                  alt={video.title}
                  width={320}
                  height={180}
                  widths={[320, 480]}
                  class="aspect-video w-full object-cover"
                  loading="lazy"
                  format="webp"
                  transition:name={`youtube-${video.id}`}
                  {...videoTransitionAttrs}
                />
                <span class="absolute bottom-3 right-3 inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/95 text-gray-900 shadow-md transition-transform duration-200 group-hover:scale-105">
                  <Icon name="mdi:play" class="w-5 h-5" />
                </span>
              </a>
              <div class="p-4">
                <a href={video.url} target="_blank" rel="noopener noreferrer">
                  <h3
                    class="line-clamp-2 text-base font-semibold leading-snug text-gray-900 transition-colors duration-200 hover:text-blue-600 dark:text-white dark:hover:text-blue-400"
                    transition:name={`youtube-title-${video.id}`}
                    {...videoTitleTransitionAttrs}
                  >
                    {video.title}
                  </h3>
                </a>
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                  {video.published.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
