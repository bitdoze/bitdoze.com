---
import { Icon } from "astro-icon/components";
import { getTransitionAnimation } from "@utils/view-transitions";

const tools = [
  {
    title: "Title Generator",
    description:
      "Create engaging, platform-specific titles for your content using AI.",
    url: "https://bitbuddies.me/tools/title-generator",
    icon: "mdi:format-title",
  },
  {
    title: "Thumbnail Ideas",
    description:
      "Generate eye-catching YouTube thumbnail concepts with AI assistance.",
    url: "https://bitbuddies.me/tools/youtube-thumbnail-generator",
    icon: "mdi:image-outline",
  },
  {
    title: "YouTube Script Generator",
    description:
      "Craft compelling YouTube video scripts with AI-powered suggestions.",
    url: "https://bitbuddies.me/tools/youtube-script-generator",
    icon: "mdi:script-text-outline",
  },
  {
    title: "Social Media Post Generator",
    description: "Generate structured Social Media Posts with AI assistance.",
    url: "https://bitbuddies.me/tools/social-post-generator",
    icon: "mdi:chart-line",
  },
];

const cardTransition = getTransitionAnimation("homeCards");
const sectionHeadingTransition = getTransitionAnimation("homeSectionHeadings");
const cardTransitionAttrs = cardTransition
  ? { ["transition:animate"]: cardTransition }
  : {};
const sectionHeadingTransitionAttrs = sectionHeadingTransition
  ? { ["transition:animate"]: sectionHeadingTransition }
  : {};

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)+/g, "");
---

<section class="py-14">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-end justify-between gap-4 mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <div>
        <h2
          class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white"
          transition:name="home-tools-heading"
          {...sectionHeadingTransitionAttrs}
        >
          Free AI tools
        </h2>
        <p
          class="mt-1 text-sm text-gray-500 dark:text-gray-400"
          transition:name="home-tools-description"
          {...sectionHeadingTransitionAttrs}
        >
          For creators — titles, thumbnails, scripts, and social posts
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        tools.map((tool) => (
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
            transition:name={`home-tool-card-${slugify(tool.title)}`}
            {...cardTransitionAttrs}
          >
            <div class="flex items-center gap-2.5 mb-2">
              <div class="rounded-md bg-blue-50 p-2 transition-colors duration-200 group-hover:bg-blue-100 dark:bg-blue-900/30 dark:group-hover:bg-blue-800/40">
                <Icon
                  name={tool.icon}
                  class="w-4 h-4 text-blue-600 dark:text-blue-400"
                />
              </div>
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">
                {tool.title}
              </h3>
              <Icon
                name="mdi:open-in-new"
                class="ml-auto w-3.5 h-3.5 shrink-0 text-gray-300 transition-colors duration-200 group-hover:text-blue-500 dark:text-gray-600 dark:group-hover:text-blue-400"
              />
            </div>
            <p class="text-xs leading-relaxed text-gray-600 dark:text-gray-300 line-clamp-2">
              {tool.description}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
