---
import { Icon } from "astro-icon/components";
import { getTransitionAnimation } from "@utils/view-transitions";

export interface Props {
  locale?: string;
}

const { locale = "en" } = Astro.props;
const isEs = locale === "es";

const heroTransition = getTransitionAnimation("homeHero");
const heroHeadingTransition = getTransitionAnimation("homeSectionHeadings");
const heroTransitionAttrs = heroTransition
  ? { ["transition:animate"]: heroTransition }
  : {};
const heroHeadingTransitionAttrs = heroHeadingTransition
  ? { ["transition:animate"]: heroHeadingTransition }
  : {};
---

<section
  class="relative overflow-hidden"
  transition:name="home-hero-section"
  {...heroTransitionAttrs}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="py-12 md:py-16 lg:py-20 grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] gap-12 lg:gap-10 items-center"
    >
      <!-- Copy -->
      <div class="max-w-xl">
        <h1
          class="text-4xl sm:text-5xl font-bold leading-[1.08] tracking-[-0.02em] text-balance text-gray-900 dark:text-white"
          transition:name="home-hero-heading"
          {...heroHeadingTransitionAttrs}
        >
          {
            isEs ? (
              <>
                Guías de DevOps que{" "}
                <span class="text-blue-600 dark:text-blue-400">realmente funcionan</span>
              </>
            ) : (
              <>
                DevOps guides that{" "}
                <span class="text-blue-600 dark:text-blue-400">actually work</span>
              </>
            )
          }
        </h1>

        <p
          class="mt-5 text-lg sm:text-xl leading-relaxed text-pretty text-gray-600 dark:text-gray-300"
          transition:name="home-hero-description"
          {...heroHeadingTransitionAttrs}
        >
          {
            isEs
              ? "Tutoriales prácticos sobre Docker, VPS, CI/CD y herramientas autoalojadas: probados de principio a fin, listos para copiar y pegar."
              : "Hands-on tutorials on Docker, VPS, CI/CD, and self-hosted tools — tested end to end, copy-paste ready, written by practitioners for practitioners."
          }
        </p>

        <!-- Proof row -->
        <ul
          class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-500 dark:text-gray-400"
        >
          <li class="inline-flex items-center gap-1.5">
            <Icon
              name="mdi:check-circle-outline"
              class="w-4 h-4 text-blue-600 dark:text-blue-400"
            />
            {isEs ? "400+ guías probadas de principio a fin" : "400+ guides tested end to end"}
          </li>
          <li class="inline-flex items-center gap-1.5">
            <Icon
              name="mdi:update"
              class="w-4 h-4 text-blue-600 dark:text-blue-400"
            />
            {isEs ? "Actualizado con las últimas versiones" : "Kept current with new releases"}
          </li>
          <li class="inline-flex items-center gap-1.5">
            <Icon
              name="mdi:account-hard-hat-outline"
              class="w-4 h-4 text-blue-600 dark:text-blue-400"
            />
            {isEs ? "10+ años de experiencia en TI" : "10+ years hands-on in IT"}
          </li>
        </ul>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-4">
          <a
            href={isEs ? "/es/blog/" : "/blog/"}
            class="group inline-flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3 text-base font-semibold text-white shadow-md transition-all duration-200 hover:bg-blue-700 hover:shadow-lg hover:-translate-y-px"
            transition:name="home-hero-cta"
            {...heroTransitionAttrs}
          >
            {isEs ? "Explorar las guías" : "Browse the guides"}
            <Icon
              name="mdi:arrow-right"
              class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-0.5"
            />
          </a>
          <a
            href={isEs ? "/es/resources/" : "/resources/"}
            class="group inline-flex items-center gap-1.5 text-base font-semibold text-gray-700 transition-colors duration-200 hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400"
          >
            <Icon
              name="mdi:gift-outline"
              class="w-5 h-5 text-blue-600 dark:text-blue-400"
            />
            {isEs ? "Herramientas y créditos gratis" : "Free tools & credits"}
            <Icon
              name="mdi:arrow-right"
              class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5"
            />
          </a>
        </div>

        <!-- Social -->
        <div
          class="mt-8 flex items-center gap-1"
          transition:name="home-hero-social"
          {...heroTransitionAttrs}
        >
          <span class="mr-2 text-xs text-gray-400 dark:text-gray-500"
            >{isEs ? "Síguenos" : "Follow along"}</span
          >
          <a
            href="https://twitter.com/bitdoze"
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors duration-200 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
            aria-label="Twitter"
          >
            <Icon name="mdi:twitter" class="w-5 h-5" />
          </a>
          <a
            href="https://bsky.app/profile/bitdoze.com"
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors duration-200 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
            aria-label="Bluesky"
          >
            <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
              <path
                d="M111.8 62.2C170.2 105.9 233 194.7 256 242.4c23-47.6 85.8-136.4 144.2-180.2c42.1-31.6 110.3-56 110.3 21.8c0 15.5-8.9 130.5-14.1 149.2C478.2 298 412 314.6 353.1 304.5c102.9 17.5 129.1 75.5 72.5 133.5c-107.4 110.2-154.3-27.6-166.3-62.9l0 0c-1.7-4.9-2.6-7.8-3.3-7.8s-1.6 3-3.3 7.8l0 0c-12 35.3-59 173.1-166.3 62.9c-56.5-58-30.4-116 72.5-133.5C100 314.6 33.8 298 15.7 233.1C10.4 214.4 1.5 99.4 1.5 83.9c0-77.8 68.2-53.4 110.3-21.8z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.youtube.com/channel/UCGsUtKhXsRrMvYAWm8q0bCg"
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors duration-200 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
            aria-label="YouTube"
          >
            <Icon name="mdi:youtube" class="w-5 h-5" />
          </a>
          <a
            href="https://github.com/bitdoze"
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors duration-200 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
            aria-label="GitHub"
          >
            <Icon name="mdi:github" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Terminal: the brand promise, visualized -->
      <div class="lg:justify-self-end w-full max-w-lg" aria-hidden="true">
        <div
          class="rounded-xl border border-[#374151] bg-[#111827] shadow-2xl shadow-gray-900/20 dark:shadow-black/40 overflow-hidden"
        >
          <!-- Title bar -->
          <div
            class="flex items-center gap-2 border-b border-[#1f2937] bg-[#0b1220] px-4 py-3"
          >
            <span class="h-3 w-3 rounded-full bg-[#ef4444]/80"></span>
            <span class="h-3 w-3 rounded-full bg-[#eab308]/80"></span>
            <span class="h-3 w-3 rounded-full bg-[#22c55e]/80"></span>
            <span
              class="ml-3 font-mono text-xs text-[#6b7280] select-none"
              >dragos@vps: ~</span
            >
            <span
              class="ml-auto inline-flex items-center gap-1 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/10 px-2 py-0.5 font-mono text-[10px] font-medium text-[#4ade80]"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e]"></span>
              deployed
            </span>
          </div>
          <!-- Session -->
          <div
            class="px-4 sm:px-5 py-4 font-mono text-[12.5px] sm:text-[13px] leading-[1.75] overflow-x-auto"
          >
            <p class="whitespace-pre">
              <span class="text-[#60a5fa]">dragos@vps</span><span
                class="text-[#6b7280]">:</span
              ><span class="text-[#93c5fd]">~</span><span
                class="text-[#6b7280]">$</span
              >
              <span class="text-[#f9fafb]">docker compose up -d</span>
            </p>
            <p class="whitespace-pre text-[#d1d5db]">
              <span class="text-[#6b7280]">[+] Running 3/3</span>
            </p>
            <p class="whitespace-pre text-[#d1d5db]">
              <span class="text-[#22c55e]"> ✔</span> Network <span
                class="text-[#9ca3af]">bitdoze_default</span
              >   <span class="text-[#22c55e]">Created</span>
            </p>
            <p class="whitespace-pre text-[#d1d5db]">
              <span class="text-[#22c55e]"> ✔</span> Container <span
                class="text-[#9ca3af]">bitdoze-db-1</span
              >  <span class="text-[#22c55e]">Started</span>
            </p>
            <p class="whitespace-pre text-[#d1d5db]">
              <span class="text-[#22c55e]"> ✔</span> Container <span
                class="text-[#9ca3af]">bitdoze-web-1</span
              > <span class="text-[#22c55e]">Started</span>
            </p>
            <p class="whitespace-pre pt-1">
              <span class="text-[#60a5fa]">dragos@vps</span><span
                class="text-[#6b7280]">:</span
              ><span class="text-[#93c5fd]">~</span><span
                class="text-[#6b7280]">$</span
              >
              <span class="text-[#f9fafb]">curl -I localhost:3000</span>
            </p>
            <p class="whitespace-pre text-[#d1d5db]">
              HTTP/1.1 <span class="text-[#22c55e] font-semibold">200 OK</span>
            </p>
            <p class="whitespace-pre pt-1">
              <span class="text-[#60a5fa]">dragos@vps</span><span
                class="text-[#6b7280]">:</span
              ><span class="text-[#93c5fd]">~</span><span
                class="text-[#6b7280]">$</span
              >
              <span
                class="hero-caret inline-block h-[1.1em] w-[0.55em] translate-y-[0.2em] bg-[#d1d5db]"
              ></span>
            </p>
          </div>
        </div>
        <p
          class="mt-3 text-center font-mono text-xs text-gray-400 dark:text-gray-500"
        >
          {isEs ? "cada guía termina aquí: funciona" : "every guide ends here: it runs"}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-caret {
    animation: hero-caret-blink 1.1s step-end infinite;
  }
  @keyframes hero-caret-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-caret {
      animation: none;
    }
  }
</style>
