---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { getTransitionAnimation } from '@utils/view-transitions';
import { isPostIdInLocale } from '@utils/i18n';
import { absoluteUrl } from '@utils/slugs';

// Get all blog posts and sort by date (newest first)
const posts = await getCollection('posts', ({ id, data }) => {
  return !data.draft && isPostIdInLocale(id, 'en');
});

// Sort posts by date (newest first)
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

// Get pagination data for first page
const { postsPerPage } = getPagination({ 
  page: 1, 
  totalPosts: sortedPosts.length, 
  basePath: '/blog' 
});

// Get posts for the first page
const paginatedPosts = sortedPosts.slice(0, postsPerPage);

const sectionHeadingTransition = getTransitionAnimation('homeSectionHeadings');
const sectionHeadingAttrs = sectionHeadingTransition
  ? { ['transition:animate']: sectionHeadingTransition }
  : {};
---

<Layout
  title={`Blog - ${siteConfig.name}`}
  description="Explore our latest articles, tutorials, and insights"
  hreflangs={[
    { lang: 'en', href: absoluteUrl('/blog/', Astro.site || siteConfig.url) },
    { lang: 'es', href: absoluteUrl('/es/blog/', Astro.site || siteConfig.url) },
    { lang: 'x-default', href: absoluteUrl('/blog/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1
        class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2"
        transition:name="home-latest-heading"
        {...sectionHeadingAttrs}
      >
        All Guides
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400" {...sectionHeadingAttrs}>
        Tested DevOps tutorials, programming guides, and self-hosted tools
      </p>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {paginatedPosts.map((post, index) => (
        <PostCard post={post} priority={index < 3} />
      ))}
    </div>
    
    <Pagination
      currentPage={1}
      totalPages={Math.ceil(sortedPosts.length / postsPerPage)}
      prevUrl={null}
      nextUrl={sortedPosts.length > postsPerPage ? `/blog/page/2/` : null}
      basePath="/blog"
    />
  </div>
</Layout>
