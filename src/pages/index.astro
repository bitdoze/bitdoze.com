---
import { getCollection } from "astro:content";
import Hero from "@components/widgets/Hero.astro";
import Tools from "@components/widgets/Tools.astro";
import YouTubeVideos from "@components/widgets/YouTubeVideos.astro";
import Layout from "@layouts/Layout.astro";
import PostCard from "@components/blog/PostCard.astro";
import PopularTopics from "@components/blog/PopularTopics.astro";
import { siteConfig } from "@config/site";
import { getTransitionAnimation } from "@utils/view-transitions";
import { isPostIdInLocale } from "@utils/i18n";
import { absoluteUrl } from "@utils/slugs";

// Get all blog posts and sort by date (newest first)
const posts = await getCollection("posts", ({ id, data }) => {
  return !data.draft && isPostIdInLocale(id, "en");
});

// Sort posts by date (newest first)
const sortedPosts = posts.sort((a, b) => {
  return (
    new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime()
  );
});

// Get the latest 6 posts for the homepage
const latestPosts = sortedPosts.slice(0, 6);

// Archive counts for the browse band
const categoryCount = new Set(
  sortedPosts.flatMap((post) => post.data.categories || []),
).size;
const tagCount = new Set(
  sortedPosts.flatMap((post) => post.data.tags || []),
).size;
const authorCount = new Set(
  sortedPosts.flatMap((post) => post.data.authors || []),
).size;

// Extract images from first 3 posts for preloading
const preloadImages = latestPosts
  .slice(0, 3)
  .map((post) => post.data.image?.src)
  .filter(Boolean);

const sectionHeadingTransition = getTransitionAnimation("homeSectionHeadings");
const sectionHeadingAttrs = sectionHeadingTransition
  ? { ["transition:animate"]: sectionHeadingTransition }
  : {};
const homeCardTransition = getTransitionAnimation("homeCards");
const homeCardAttrs = homeCardTransition
  ? { ["transition:animate"]: homeCardTransition }
  : {};
---

<Layout
  title={siteConfig.name}
  description={siteConfig.description}
  wideContent={true}
  preloadImages={preloadImages}
  hreflangs={[
    { lang: "en", href: absoluteUrl("/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="w-full py-8">
    <!-- Hero Section -->
    <Hero />

    <!-- Blog Posts Section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between gap-4 mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
        <div>
          <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white"
            transition:name="home-latest-heading"
            {...sectionHeadingAttrs}
          >
            Latest guides
          </h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Tested this month, ready to copy-paste
          </p>
        </div>
        <a
          href="/blog/"
          class="group inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
        >
          View all guides
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          latestPosts.map((post, index) => (
            <PostCard post={post} priority={index < 3} />
          ))
        }
      </div>
    </section>

    <!-- Popular Topics Section -->
    <PopularTopics tags={["docker", "astro", "carrd"]} postsPerTag={5} />

    <!-- YouTube Videos Section -->
    <YouTubeVideos />

    <!-- AI Tools Section (external; demoted below own content) -->
    <Tools />

    <!-- Browse the Archive -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-14">
      <div
        class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-5 shadow-sm"
        transition:name="home-explore-categories"
        {...homeCardAttrs}
      >
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
          <h2
            class="shrink-0 text-sm font-semibold text-gray-900 dark:text-white"
            transition:name="home-explore-heading"
            {...sectionHeadingAttrs}
          >
            Browse the archive
          </h2>
          <div
            class="flex flex-col gap-1 sm:ml-auto sm:flex-row sm:items-center sm:gap-2"
          >
            <a
              href="/categories/"
              class="group inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition-colors duration-200 hover:bg-gray-50 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-700/60 dark:hover:text-blue-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 text-blue-600 dark:text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                ></path>
              </svg>
              Categories
              <span class="text-xs text-gray-400 dark:text-gray-500"
                >{categoryCount}</span
              >
            </a>
            <a
              href="/tags/"
              class="group inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition-colors duration-200 hover:bg-gray-50 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-700/60 dark:hover:text-blue-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 text-blue-600 dark:text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                ></path>
              </svg>
              Tags
              <span class="text-xs text-gray-400 dark:text-gray-500"
                >{tagCount}</span
              >
            </a>
            <a
              href="/authors/"
              class="group inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition-colors duration-200 hover:bg-gray-50 hover:text-blue-600 dark:text-gray-300 dark:hover:bg-gray-700/60 dark:hover:text-blue-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 text-blue-600 dark:text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
              Authors
              <span class="text-xs text-gray-400 dark:text-gray-500"
                >{authorCount}</span
              >
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
