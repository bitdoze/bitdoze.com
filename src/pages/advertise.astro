---
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

// Page info
const title = "Advertise with Bitdoze";
const description = "Reach 27,000+ monthly developers and tech enthusiasts. Bypass adblockers with native advertising.";

// Stats
const stats = [
  { value: "27K+", label: "Unique Visitors", icon: "mdi:account-group" },
  { value: "30K+", label: "Page Views", icon: "mdi:eye" },
  { value: "41K+", label: "Page Sessions", icon: "mdi:cursor-default-click" },
  { value: "DR 24-32", label: "Domain Rating", icon: "mdi:chart-line" },
];

// Pricing packages
const packages = [
  {
    name: "Premium Banner",
    description: "Stay on top of every page with maximum visibility",
    price: 300,
    period: "monthly",
    featured: true,
    features: [
      "Featured on top of every page",
      "Access to 27K+ monthly developers",
      "Bypass any adblocker",
      "A dofollow backlink on a DR 24-32 domain",
      "Live within 24 hours",
    ],
    cta: "Get Started",
  },
  {
    name: "Sidebar Placement",
    description: "Be visible in the sidebar on every article",
    price: 200,
    period: "monthly",
    featured: false,
    features: [
      "Visibility in sidebar on every article",
      "Bypass any adblocker",
      "Access to 27K+ monthly developers",
      "A dofollow backlink on a DR 24-32 domain",
      "Live within 24 hours",
    ],
    cta: "Get Started",
  },
  {
    name: "Sponsored Article",
    description: "Permanent placement with a dedicated article",
    price: 250,
    period: "one-time",
    featured: false,
    features: [
      "Featured on top of articles for a week",
      "Access to 27K+ monthly developers",
      "A dofollow backlink on a DR 24-32 domain",
      "Permanent position on the platform",
      "Full editorial control",
    ],
    cta: "Get Started",
  },
];

// Benefits
const benefits = [
  {
    icon: "mdi:shield-check",
    title: "Bypass Adblockers",
    description: "Native advertising that reaches your audience without being blocked by any adblocker.",
  },
  {
    icon: "mdi:target",
    title: "Targeted Audience",
    description: "Reach developers and tech enthusiasts actively seeking solutions like yours.",
  },
  {
    icon: "mdi:link-variant",
    title: "Quality Backlinks",
    description: "Get valuable dofollow backlinks from a growing tech domain with DR 24-32.",
  },
  {
    icon: "mdi:chart-areaspline",
    title: "Transparent Analytics",
    description: "Full access to our public analytics dashboard to track performance anytime.",
  },
];

// FAQ items
const faqs = [
  {
    question: "How quickly will my ad go live?",
    answer: "Once we receive your payment and creative materials, your ad will be live within 24 hours.",
  },
  {
    question: "What information do you need from me?",
    answer: "We need your company logo, a short description, and the URL you want to link to. For sponsored articles, we'll need the full article content.",
  },
  {
    question: "Can I see the analytics for my ad?",
    answer: "Yes! Our analytics dashboard is public. You can view all traffic statistics at any time to track performance.",
  },
  {
    question: "Are the backlinks dofollow?",
    answer: "Yes, all backlinks from advertising placements are dofollow links that pass SEO value to your website.",
  },
];
---

<Layout
  title={title}
  description={description}
  wideContent={true}
  hreflangs={[
    { lang: "en", href: absoluteUrl("/advertise/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/advertise/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/advertise/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="w-full">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white dark:bg-gray-900 py-12 md:py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl md:text-5xl font-bold leading-tight tracking-tight text-gray-900 dark:text-white mb-4">
          Show Off Your Business to{" "}
          <span class="text-blue-600 dark:text-blue-400">
            27,000+ Developers
          </span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-8">
          Access an engaged audience of developers and tech enthusiasts while bypassing adblockers with native advertising.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#packages"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 text-base font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-px"
          >
            <Icon name="mdi:tag" class="w-5 h-5" />
            View Packages
          </a>
          <a
            href="https://an3.bitdoze.com/bitdoze.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 text-base font-semibold text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-all duration-200"
          >
            <Icon name="mdi:chart-bar" class="w-5 h-5" />
            View Analytics
          </a>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map((stat) => (
          <div class="text-center p-6 rounded-xl bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 mb-3">
              <Icon name={stat.icon} class="w-5 h-5" />
            </div>
            <div class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-1">{stat.value}</div>
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
          Why Advertise With Us?
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Get your product or service in front of developers who are actively looking for solutions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {benefits.map((benefit) => (
          <div class="group flex gap-4 p-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-all duration-200">
            <div class="shrink-0">
              <div class="w-12 h-12 rounded-lg bg-blue-600 text-white flex items-center justify-center shadow-sm">
                <Icon name={benefit.icon} class="w-6 h-6" />
              </div>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">
                {benefit.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                {benefit.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing Packages Section -->
    <section id="packages" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 scroll-mt-20">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
          Advertising Packages
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Choose the package that best fits your marketing goals. All packages include native advertising that bypasses adblockers.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {packages.map((pkg) => (
          <div
            class={`relative flex flex-col p-6 rounded-xl border transition-all duration-200 ${
              pkg.featured
                ? 'bg-blue-600 text-white border-blue-600 shadow-md'
                : 'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md'
            }`}
          >
            {pkg.featured && (
              <div class="mb-4">
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-white/20 backdrop-blur-xs text-white text-xs font-semibold rounded-full">
                  <Icon name="mdi:star" class="w-3.5 h-3.5" />
                  Most Popular
                </span>
              </div>
            )}

            <div class="mb-4">
              <h3 class={`text-xl font-bold mb-1 ${pkg.featured ? 'text-white' : 'text-gray-900 dark:text-white'}`}>
                {pkg.name}
              </h3>
              <p class={`text-xs ${pkg.featured ? 'text-blue-100' : 'text-gray-500 dark:text-gray-400'}`}>
                {pkg.description}
              </p>
            </div>

            <div class="mb-6">
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-bold ${pkg.featured ? 'text-white' : 'text-gray-900 dark:text-white'}`}>
                  ${pkg.price}
                </span>
                <span class={`text-xs ${pkg.featured ? 'text-blue-100' : 'text-gray-500 dark:text-gray-400'}`}>
                  USD / {pkg.period}
                </span>
              </div>
            </div>

            <ul class="space-y-3 mb-6 grow">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-2.5">
                  <Icon
                    name="mdi:check-circle"
                    class={`w-4 h-4 mt-0.5 shrink-0 ${pkg.featured ? 'text-blue-200' : 'text-green-500'}`}
                  />
                  <span class={`text-xs leading-relaxed ${pkg.featured ? 'text-blue-50' : 'text-gray-600 dark:text-gray-300'}`}>
                    {feature}
                  </span>
                </li>
              ))}
            </ul>

            <a
              href="/contact/"
              class={`inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg text-sm font-semibold transition-all duration-200 ${
                pkg.featured
                  ? 'bg-white text-blue-600 hover:bg-gray-100'
                  : 'bg-blue-600 text-white hover:bg-blue-700'
              }`}
            >
              {pkg.cta}
              <Icon name="mdi:arrow-right" class="w-4 h-4" />
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
          Frequently Asked Questions
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400">
          Everything you need to know about advertising with us
        </p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 shadow-sm">
            <summary class="flex items-center justify-between gap-4 cursor-pointer font-semibold text-gray-900 dark:text-white">
              <span>{faq.question}</span>
              <Icon name="mdi:chevron-down" class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" />
            </summary>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </section>
  </div>
</Layout>
