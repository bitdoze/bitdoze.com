---
import Layout from "@layouts/Layout.astro";
import ServicesHub from "@components/services/ServicesHub.astro";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

const title = "Technical Services";
const description = "Explore Bitdoze services for Astro development, AI agents, VPS setup, self-hosted apps, and Dokploy deployments.";
---

<Layout
  title={title}
  description={description}
  wideContent={true}
  hreflangs={[
    { lang: "en", href: absoluteUrl("/services/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/services/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/services/", Astro.site || siteConfig.url) },
  ]}
>
  <ServicesHub locale="en" />
</Layout>
