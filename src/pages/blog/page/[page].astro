---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { absoluteUrl } from '@utils/slugs';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('posts', ({ id, data }) => {
    return !data.draft && isPostIdInLocale(id, 'en');
  });

  const sortedPosts = posts.sort((a, b) => {
    return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
  });

  const allPages = paginate(sortedPosts, { pageSize: siteConfig.postsPerPage });
  // Skip page 1 since it's handled by blog.astro
  return allPages.filter((entry) => entry.params.page !== '1');
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const basePath = '/blog';

// Override prev URL: page 2's prev should link to /blog/ not /blog/page/1/
const prevUrl = currentPage === 2 ? `${basePath}/` : (page.url.prev ?? null);
---

<Layout
  title={`Blog - Page ${currentPage} - ${siteConfig.name}`}
  description={`Explore our articles, tutorials, and insights - Page ${currentPage}`}
  noindex={true}
  hreflangs={[
    { lang: 'en', href: absoluteUrl(`/blog/page/${currentPage}/`, Astro.site || siteConfig.url) },
    { lang: 'es', href: absoluteUrl(`/es/blog/page/${currentPage}/`, Astro.site || siteConfig.url) },
    { lang: 'x-default', href: absoluteUrl(`/blog/page/${currentPage}/`, Astro.site || siteConfig.url) },
  ]}
>
  <div class="w-full py-8">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">Blog</h1>
      <p class="text-lg text-gray-700 dark:text-gray-300">
        Page {currentPage} of {totalPages} - Explore our articles, tutorials, and insights
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {page.data.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={prevUrl}
      nextUrl={page.url.next ?? null}
      basePath={basePath}
    />
  </div>
</Layout>
