---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { getTransitionAnimation } from '@utils/view-transitions';
import { isPostIdInLocale } from '@utils/i18n';
import { absoluteUrl, buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

// Get all blog posts
const posts = await getCollection('posts', ({ id, data }) => {
  return !data.draft && isPostIdInLocale(id, 'en');
});

// Get all unique tags and count posts for each
// Ensure we're collecting all tags, even if they're empty arrays
const tags = getUniqueTaxonomyValues(posts.flatMap(post => post.data.tags || []));
const tagCounts = tags.map(tag => {
  const count = posts.filter(post => 
    post.data.tags?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(tag))
  ).length;
  
  return {
    name: tag,
    count,
    slug: toTaxonomySlug(tag)
  };
}).sort((a, b) => b.count - a.count); // Sort by post count (descending)

const homeCardTransition = getTransitionAnimation('homeCards');
const homeCardAttrs = homeCardTransition
  ? { ['transition:animate']: homeCardTransition }
  : {};
---

<Layout 
  title={`Tags - ${siteConfig.name}`}
  description="Browse all tags and topics on our blog"
  hreflangs={[
    { lang: 'en', href: absoluteUrl('/tags/', Astro.site || siteConfig.url) },
    { lang: 'es', href: absoluteUrl('/es/tags/', Astro.site || siteConfig.url) },
    { lang: 'x-default', href: absoluteUrl('/tags/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header
      class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700"
      transition:name="home-explore-tags"
      {...homeCardAttrs}
    >
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Tags
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        Browse posts by tag
      </p>
    </header>
    
    <div class="flex flex-wrap gap-2.5">
      {tagCounts.map(({ name, count, slug }) => (
        <a 
          href={buildArchivePath('tags', slug, 'en')}
          class="group inline-flex items-center gap-2 px-3.5 py-2 bg-white dark:bg-gray-800 rounded-full border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md hover:border-blue-300 dark:hover:border-blue-700"
        >
          <span class="font-medium text-sm text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
            #{name.charAt(0).toUpperCase() + name.slice(1)}
          </span>
          <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-xs font-semibold px-2 py-0.5 rounded-full">
            {count}
          </span>
        </a>
      ))}
    </div>
    
    {tagCounts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No tags found.</p>
      </div>
    )}
  </div>
</Layout>
