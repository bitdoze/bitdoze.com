---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id, data }) => {
    return !data.draft && isPostIdInLocale(id, 'en');
  });
  
  // Get all unique categories
  const categories = getUniqueTaxonomyValues(posts.flatMap(post => post.data.categories || []));
  
  return categories.map(category => {
    // Filter posts by category
    const categoryPosts = posts.filter(post => 
      post.data.categories?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(category))
    ).sort((a, b) => {
      return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
    });
    
    return {
      params: { category: toTaxonomySlug(category) },
      props: { 
        category,
        posts: categoryPosts,
        count: categoryPosts.length
      }
    };
  });
}

const { category, posts, count } = Astro.props;
const basePath = buildArchivePath('categories', toTaxonomySlug(category), 'en').replace(/\/$/, '');

// Get pagination data for first page
const { postsPerPage } = getPagination({ 
  page: 1, 
  totalPosts: count, 
  basePath 
});

// Get posts for the first page
const paginatedPosts = posts.slice(0, postsPerPage);

// Set noindex based on site config
const noindex = siteConfig.noindex.categories;

// Format the category name for display
const formattedCategory = category.charAt(0).toUpperCase() + category.slice(1);
---

<Layout 
  title={`${formattedCategory} - ${siteConfig.name}`}
  description={`Browse all posts in the ${formattedCategory} category`}
  noindex={noindex}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Category: {formattedCategory}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {count} {count === 1 ? 'guide' : 'guides'} in this category
      </p>
    </header>
    
    {count > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {paginatedPosts.map((post, index) => (
          <PostCard post={post} priority={index < 3} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No guides found in this category.</p>
      </div>
    )}
    
    <Pagination
      currentPage={1}
      totalPages={Math.ceil(count / postsPerPage)}
      prevUrl={null}
      nextUrl={count > postsPerPage ? `${basePath}/page/2/` : null}
      basePath={basePath}
    />
  </div>
</Layout>
