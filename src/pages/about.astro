---
import Layout from "@layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

const aboutEntries = await getCollection("about");
const entry = aboutEntries.find((item) => item.id === "index");

if (!entry) {
  throw new Error("About entry not found");
}

const { Content } = await render(entry);
const { title, description, image, what_i_do } = entry.data;
---

<Layout
  title={title}
  description={description}
  hreflangs={[
    { lang: "en", href: absoluteUrl("/about/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/about/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/about/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- About Hero Section -->
    <section class="py-6">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        {image && (
          <div class="md:w-1/3 shrink-0">
            <img
              src={image}
              alt={title}
              class="rounded-xl w-full border border-gray-200 dark:border-gray-700 shadow-sm object-cover"
            />
          </div>
        )}
        <div class="md:w-2/3">
          <header class="mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">{title}</h1>
            <p class="text-base text-gray-600 dark:text-gray-400">Practitioner guides for DevOps engineers & developers</p>
          </header>

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Content />
          </div>
          <div class="mt-8">
            <a
              href="/contact"
              class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all duration-200 font-semibold shadow-md hover:shadow-lg hover:-translate-y-px"
            >
              Get In Touch
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- What I Do Section -->
    <section class="mt-14 pt-10 border-t border-gray-200 dark:border-gray-700">
      <div class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">{what_i_do.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {what_i_do.items.map((item: any) => (
          <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            {item.icon && <i class={`${item.icon} text-3xl text-blue-600 dark:text-blue-400 mb-4 block`}></i>}
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{item.title}</h3>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.description}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
