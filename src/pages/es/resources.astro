---
import Layout from "@layouts/Layout.astro";
import ResourceCard from "@components/widgets/ResourceCard.astro";
import resourcesData from "@config/resources.json";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

const { resources } = resourcesData;

const groupedResources = resources.reduce((acc, resource) => {
  const category = resource.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(resource);
  return acc;
}, {} as Record<string, typeof resources>);

const sortedCategories = Object.keys(groupedResources).sort();

const title = "Recursos y herramientas recomendadas";
const description =
  "Descubre herramientas seleccionadas para hosting, desarrollo, email marketing y productividad.";
---

<Layout
  title={`${title} - ${siteConfig.name}`}
  description={description}
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl("/resources/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/resources/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/resources/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        {title}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {description}
      </p>
    </header>

    <section class="space-y-12">
      {sortedCategories.map((category) => (
        <div>
          <div class="mb-6 flex items-center justify-between border-b-2 border-blue-600 dark:border-blue-400 pb-2">
            <h2 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white">
              {category}
            </h2>
            <span class="text-xs font-semibold text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/40 px-2.5 py-0.5 rounded-full">
              {groupedResources[category].length} {groupedResources[category].length === 1 ? 'herramienta' : 'herramientas'}
            </span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {groupedResources[category].map((resource) => (
              <div class="h-full">
                <ResourceCard resource={resource} />
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-14 pt-10 border-t border-gray-200 dark:border-gray-700 text-center">
      <h2 class="text-xl md:text-2xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        ¿Quieres recomendar una herramienta?
      </h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
        Si conoces una opción genial que deba estar aquí, ¡envíanos un mensaje!
      </p>
      <a
        href="/es/contact/"
        class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-px"
      >
        Contactar
      </a>
    </section>
  </div>
</Layout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>
