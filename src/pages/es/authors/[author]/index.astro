---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id, data }) => !data.draft && isPostIdInLocale(id, 'es'));
  const authorEntries = await getCollection('authors');
  const authors = getUniqueTaxonomyValues(posts.flatMap((post) => post.data.authors || []));

  return authors.map((author) => {
    const authorPosts = posts
      .filter((post) => post.data.authors?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(author)))
      .sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());

    const authorDetails =
      authorEntries.find((entry) => entry.data.title.toLowerCase() === author.toLowerCase()) || null;

    return {
      params: { author: toTaxonomySlug(author) },
      props: {
        author,
        authorDetails,
        posts: authorPosts,
        count: authorPosts.length,
      },
    };
  });
}

const { author, authorDetails, posts, count } = Astro.props as {
  author: string;
  authorDetails: CollectionEntry<'authors'> | null;
  posts: CollectionEntry<'posts'>[];
  count: number;
};
const basePath = buildArchivePath('authors', toTaxonomySlug(author), 'es').replace(/\/$/, '');
const { postsPerPage } = getPagination({ page: 1, totalPosts: count, basePath });
const paginatedPosts = posts.slice(0, postsPerPage);
const noindex = siteConfig.noindex.authors;
const formattedAuthor = author
  .split(' ')
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
  .join(' ');
const authorContent = authorDetails ? await render(authorDetails) : null;
---

<Layout
  title={`Artículos de ${formattedAuthor} - ${siteConfig.name}`}
  description={`Explora los artículos escritos por ${formattedAuthor}`}
  noindex={noindex}
  lang="es"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Autor: {formattedAuthor}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {count} {count === 1 ? 'guía' : 'guías'} de este autor
      </p>
    </header>

    {authorDetails && (
      <div class="mb-12 bg-white dark:bg-gray-800 rounded-xl shadow-sm overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="p-6 md:p-8">
          <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
            {authorDetails.data.image && (
              <div class="shrink-0 text-center">
                <div class="w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden border-2 border-gray-200 dark:border-gray-700 shadow-sm mx-auto">
                  <img
                    src={authorDetails.data.image}
                    alt={authorDetails.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>

                {authorDetails.data.social && (
                  <div class="mt-4 flex justify-center gap-3">
                    {authorDetails.data.social.twitter && (
                      <a
                        href={authorDetails.data.social.twitter}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors"
                        aria-label={`${authorDetails.data.title} en Twitter`}
                      >
                        <Icon name="mdi:twitter" class="w-5 h-5" />
                      </a>
                    )}
                    {authorDetails.data.social.facebook && (
                      <a
                        href={authorDetails.data.social.facebook}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors"
                        aria-label={`${authorDetails.data.title} en Facebook`}
                      >
                        <Icon name="mdi:facebook" class="w-5 h-5" />
                      </a>
                    )}
                    {authorDetails.data.social.instagram && (
                      <a
                        href={authorDetails.data.social.instagram}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-500 hover:text-pink-600 dark:text-gray-400 dark:hover:text-pink-400 transition-colors"
                        aria-label={`${authorDetails.data.title} en Instagram`}
                      >
                        <Icon name="mdi:instagram" class="w-5 h-5" />
                      </a>
                    )}
                  </div>
                )}
              </div>
            )}

            <div class="grow">
              <div class="prose prose-lg dark:prose-invert max-w-none">
                {authorContent && <authorContent.Content />}
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    {count > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {paginatedPosts.map((post, index) => (
          <PostCard post={post} priority={index < 3} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No se encontraron artículos de este autor.</p>
      </div>
    )}

    <Pagination
      currentPage={1}
      totalPages={Math.ceil(count / postsPerPage)}
      prevUrl={null}
      nextUrl={count > postsPerPage ? `${basePath}/page/2/` : null}
      basePath={basePath}
    />
  </div>
</Layout>
