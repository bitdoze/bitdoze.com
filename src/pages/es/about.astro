---
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";
---

<Layout
  title={`Acerca de - ${siteConfig.name}`}
  description="Conoce al autor de Bitdoze y el enfoque del blog en DevOps, programación y herramientas prácticas."
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl("/about/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/about/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/about/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <section class="py-6">
      <header class="mb-8 pb-4 border-b border-gray-200 dark:border-gray-700">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">Acerca de Bitdoze</h1>
        <p class="text-base text-gray-600 dark:text-gray-400">Guías prácticas sobre DevOps, Linux y desarrollo</p>
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-none">
        <p>
          Soy Dragos, profesional de IT con foco en DevOps, Linux y contenido técnico. En Bitdoze publico guías
          prácticas para ayudarte a desplegar, optimizar y mantener proyectos reales.
        </p>
        <p>
          El objetivo del sitio es simple: contenido accionable, ejemplos claros y comparativas útiles para que tomes
          mejores decisiones técnicas.
        </p>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">En qué te puedo ayudar</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Despliegue VPS</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">Configuración y despliegue eficiente de aplicaciones y servicios en VPS.</p>
          </div>
          <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Docker &amp; Seguridad</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">Contenerización, observabilidad y mejores prácticas de seguridad básica.</p>
          </div>
          <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Automatización</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">Productividad para desarrollo y flujos automatizados de CI/CD.</p>
          </div>
        </div>
      </div>

      <div class="mt-8">
        <a
          href="/es/contact/"
          class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all duration-200 font-semibold shadow-md hover:shadow-lg hover:-translate-y-px"
        >
          Contactar
        </a>
      </div>
    </section>
  </div>
</Layout>
