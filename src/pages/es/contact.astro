---
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

const title = "Contacto";
const { email, address, phone, formAction } = siteConfig.contact;
const description =
  "Ponte en contacto con Bitdoze sobre DevOps, self-hosting o colaboraciones.";
const inputClass =
  "w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors";
---

<Layout
  title={`${title} - ${siteConfig.name}`}
  description={description}
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl("/contact/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/contact/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/contact/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        {title}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {description}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-4">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">
            Información de contacto
          </h2>
          <ul class="flex flex-col space-y-6">
            {
              address && (
                <li>
                  <div class="flex text-gray-900 dark:text-white items-center text-base font-semibold">
                    <Icon
                      name="mdi:map-marker-outline"
                      class="mr-2 text-blue-600 dark:text-blue-400 text-xl shrink-0"
                    />
                    <span>Ubicación</span>
                  </div>
                  <p class="mt-1 text-sm text-gray-600 dark:text-gray-300 pl-7">{address}</p>
                </li>
              )
            }
            <li>
              <div class="flex text-gray-900 dark:text-white items-center text-base font-semibold">
                <Icon name="mdi:email-outline" class="mr-2 text-blue-600 dark:text-blue-400 text-xl shrink-0" />
                <span>Email</span>
              </div>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-300 pl-7">
                <a
                  href={`mailto:${email}`}
                  class="text-blue-600 dark:text-blue-400 hover:underline"
                  >{email}</a
                >
              </p>
            </li>
            {
              phone && (
                <li>
                  <div class="flex text-gray-900 dark:text-white items-center text-base font-semibold">
                    <Icon name="mdi:phone-outline" class="mr-2 text-blue-600 dark:text-blue-400 text-xl shrink-0" />
                    <span>Teléfono</span>
                  </div>
                  <p class="mt-1 text-sm text-gray-600 dark:text-gray-300 pl-7">
                    <a
                      href={`tel:${phone.replace(/\s+/g, "")}`}
                      class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                      >{phone}</a
                    >
                  </p>
                </li>
              )
            }
          </ul>
        </div>
      </div>
      <div class="md:col-span-8">
        <form
          class="bg-white dark:bg-gray-800 p-6 md:p-8 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm"
          method="POST"
          action={formAction}
          data-astro-reload
        >
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_subject" value="Bitdoze formulario de contacto" />
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              <span class="mb-1.5 block">Nombre <span class="text-red-500">*</span></span>
              <input class={inputClass} name="name" type="text" required />
            </label>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              <span class="mb-1.5 block">Email <span class="text-red-500">*</span></span>
              <input class={inputClass} name="email" type="email" required />
            </label>
          </div>
          <label class="mb-4 block text-sm font-medium text-gray-700 dark:text-gray-300">
            <span class="mb-1.5 block">Asunto</span>
            <input class={inputClass} name="subject" type="text" />
          </label>
          <label class="mb-6 block text-sm font-medium text-gray-700 dark:text-gray-300">
            <span class="mb-1.5 block">Mensaje <span class="text-red-500">*</span></span>
            <textarea class={inputClass} name="message" rows="4" required></textarea>
          </label>
          <button
            type="submit"
            class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-md hover:shadow-lg transition-all duration-200 hover:-translate-y-px"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
