---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id, data }) => !data.draft && isPostIdInLocale(id, 'es'));
  const categories = getUniqueTaxonomyValues(posts.flatMap((post) => post.data.categories || []));

  return categories.flatMap((category) => {
    const categoryPosts = posts
      .filter((post) => post.data.categories?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(category)))
      .sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());

    const totalPages = Math.ceil(categoryPosts.length / siteConfig.postsPerPage);

    return Array.from({ length: totalPages }).map((_, i) => {
      const page = i + 1;
      if (page === 1) return null;

      return {
        params: {
          category: toTaxonomySlug(category),
          page: page.toString(),
        },
        props: {
          category,
          posts: categoryPosts,
          page,
          count: categoryPosts.length,
        },
      };
    }).filter(Boolean);
  });
}

const { category, posts, page, count } = Astro.props as {
  category: string;
  posts: CollectionEntry<'posts'>[];
  page: string | number;
  count: number;
};

const currentPage = typeof page === 'number' ? page : parseInt(page, 10);
const basePath = buildArchivePath('categories', toTaxonomySlug(category), 'es').replace(/\/$/, '');

const { startIndex, endIndex, prevUrl, nextUrl, totalPages } = getPagination({
  page: currentPage,
  totalPosts: count,
  basePath,
});

const paginatedPosts = posts.slice(startIndex, endIndex);
const noindex = siteConfig.noindex.categories;
const formattedCategory = category.charAt(0).toUpperCase() + category.slice(1);
---

<Layout
  title={`${formattedCategory} - Página ${currentPage} - ${siteConfig.name}`}
  description={`Artículos en ${formattedCategory} - Página ${currentPage}`}
  noindex={noindex}
  lang="es"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Categoría: {formattedCategory}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        Página {currentPage} de {totalPages} — {count} {count === 1 ? 'guía' : 'guías'} en esta categoría
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {paginatedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      basePath={basePath}
    />
  </div>
</Layout>
