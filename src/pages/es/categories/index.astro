---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { absoluteUrl, buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

const posts = await getCollection('posts', ({ id, data }) => !data.draft && isPostIdInLocale(id, 'es'));
const categories = getUniqueTaxonomyValues(posts.flatMap((post) => post.data.categories || []));
const categoryCounts = categories.map((category) => ({
  name: category,
  count: posts.filter((post) => post.data.categories?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(category))).length,
  slug: toTaxonomySlug(category),
})).sort((a, b) => b.count - a.count);
---

<Layout
  title={`Categorías - ${siteConfig.name}`}
  description="Categorías del contenido en español"
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl('/categories/', Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl('/es/categories/', Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl('/categories/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">Categorías</h1>
      <p class="text-base text-gray-600 dark:text-gray-400">Explora artículos por categoría.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryCounts.map(({ name, count, slug }) => (
        <a
          href={buildArchivePath('categories', slug, 'es')}
          class="group flex items-center justify-between p-5 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md hover:border-blue-300 dark:hover:border-blue-700"
        >
          <div class="flex items-center">
            <Icon name="mdi:folder-outline" class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-3 shrink-0 transition-transform duration-200 group-hover:scale-110" />
            <span class="font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{name.charAt(0).toUpperCase() + name.slice(1)}</span>
          </div>
          <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-xs font-semibold px-2.5 py-0.5 rounded-full">{count} {count === 1 ? 'artículo' : 'artículos'}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
