---
import Layout from "@layouts/Layout.astro";
import ServiceDetail from "@components/services/ServiceDetail.astro";
import { getServicePath, getServices, type ServiceConfig } from "@config/services";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

export async function getStaticPaths() {
  return getServices("es").map((service) => ({
    params: { service: service.slug.es },
    props: { service },
  }));
}

const { service } = Astro.props as { service: ServiceConfig };
const title = service.title.es;
const description = service.heroDescription.es;
---

<Layout
  title={`${title} - ${siteConfig.name}`}
  description={description}
  wideContent={true}
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl(getServicePath(service, "en"), Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl(getServicePath(service, "es"), Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl(getServicePath(service, "en"), Astro.site || siteConfig.url) },
  ]}
>
  <ServiceDetail locale="es" service={service} />
</Layout>
