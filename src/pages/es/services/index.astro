---
import Layout from "@layouts/Layout.astro";
import ServicesHub from "@components/services/ServicesHub.astro";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";

const title = "Servicios tecnicos";
const description = "Explora los servicios de Bitdoze para Astro, agentes IA, VPS, apps self-hosted y despliegues con Dokploy.";
---

<Layout
  title={`${title} - ${siteConfig.name}`}
  description={description}
  wideContent={true}
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl("/services/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/services/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/services/", Astro.site || siteConfig.url) },
  ]}
>
  <ServicesHub locale="es" />
</Layout>
