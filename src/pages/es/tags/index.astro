---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { absoluteUrl, buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

const posts = await getCollection('posts', ({ id, data }) => !data.draft && isPostIdInLocale(id, 'es'));
const tags = getUniqueTaxonomyValues(posts.flatMap((post) => post.data.tags || []));
const tagCounts = tags.map((tag) => ({
  name: tag,
  count: posts.filter((post) => post.data.tags?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(tag))).length,
  slug: toTaxonomySlug(tag),
})).sort((a, b) => b.count - a.count);
---

<Layout
  title={`Etiquetas - ${siteConfig.name}`}
  description="Etiquetas del contenido en español"
  lang="es"
  hreflangs={[
    { lang: "en", href: absoluteUrl('/tags/', Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl('/es/tags/', Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl('/tags/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">Etiquetas</h1>
      <p class="text-base text-gray-600 dark:text-gray-400">Explora artículos por etiqueta.</p>
    </header>

    <div class="flex flex-wrap gap-2.5">
      {tagCounts.map(({ name, count, slug }) => (
        <a
          href={buildArchivePath('tags', slug, 'es')}
          class="group inline-flex items-center gap-2 px-3.5 py-2 bg-white dark:bg-gray-800 rounded-full border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md hover:border-blue-300 dark:hover:border-blue-700"
        >
          <span class="font-medium text-sm text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">#{name}</span>
          <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-xs font-semibold px-2 py-0.5 rounded-full">{count}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
