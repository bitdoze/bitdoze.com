---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { isPostIdInLocale } from '@utils/i18n';
import { buildArchivePath, getUniqueTaxonomyValues, toTaxonomySlug } from '@utils/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id, data }) => !data.draft && isPostIdInLocale(id, 'es'));
  const tags = getUniqueTaxonomyValues(
    posts.flatMap((post) => Array.isArray(post.data.tags) ? post.data.tags : [])
  );

  return tags.map((tag) => {
    const tagPosts = posts
      .filter((post) => post.data.tags?.some((entry) => toTaxonomySlug(entry) === toTaxonomySlug(tag)))
      .sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());

    return {
      params: { tag: toTaxonomySlug(tag) },
      props: {
        tag,
        posts: tagPosts,
        count: tagPosts.length,
      },
    };
  });
}

const { tag, posts, count } = Astro.props;
const basePath = buildArchivePath('tags', toTaxonomySlug(tag), 'es').replace(/\/$/, '');

const { postsPerPage } = getPagination({
  page: 1,
  totalPosts: count,
  basePath,
});

const paginatedPosts = posts.slice(0, postsPerPage);
const noindex = siteConfig.noindex.tags;
const formattedTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<Layout
  title={`Etiqueta ${formattedTag} - ${siteConfig.name}`}
  description={`Artículos con la etiqueta ${formattedTag}`}
  noindex={noindex}
  lang="es"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Etiqueta: #{formattedTag}
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {count} {count === 1 ? 'guía' : 'guías'} con esta etiqueta
      </p>
    </header>

    {count > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {paginatedPosts.map((post, index) => (
          <PostCard post={post} priority={index < 3} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No se encontraron artículos.</p>
      </div>
    )}

    <Pagination
      currentPage={1}
      totalPages={Math.ceil(count / postsPerPage)}
      prevUrl={null}
      nextUrl={count > postsPerPage ? `${basePath}/page/2/` : null}
      basePath={basePath}
    />
  </div>
</Layout>
