---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { absoluteUrl } from '@utils/slugs';
---

<Layout
  title={`Buscar - ${siteConfig.name}`}
  description="Busca articulos y tutoriales en Bitdoze"
  noindex={true}
  lang="es"
  hreflangs={[
    { lang: 'en', href: absoluteUrl('/search/', Astro.site || siteConfig.url) },
    { lang: 'es', href: absoluteUrl('/es/search/', Astro.site || siteConfig.url) },
    { lang: 'x-default', href: absoluteUrl('/search/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">Buscar</h1>

    <div id="search"></div>
  </div>
</Layout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    var script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.type = 'module';
    script.onerror = function () {
      var el = document.getElementById('search');
      if (el) el.innerHTML = '<p class="text-center text-gray-500">El indice de busqueda se esta construyendo. Intenta mas tarde.</p>';
    };
    script.onload = function () {
      new PagefindUI({ element: '#search', showSubResults: true });
    };
    document.head.appendChild(script);
  })();
</script>
