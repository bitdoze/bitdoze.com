---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import Breadcrumb from '@components/common/Breadcrumb.astro';
import { getEntryHref, getEntrySlug } from '@utils/content';
import { getTransitionAnimation } from '@utils/view-transitions';
import { isPostIdInLocale } from '@utils/i18n';
import { siteConfig } from '@config/site';
import { absoluteUrl } from '@utils/slugs';

// Get all posts
const allPosts = await getCollection('posts', ({ id, data }) => {
  return !data.draft && isPostIdInLocale(id, 'en');
});

// Extract series information
const seriesMap = new Map();

allPosts.forEach(post => {
  if (post.data.series && Array.isArray(post.data.series) && post.data.series.length === 2) {
    const seriesName = post.data.series[0];
    const seriesPosition = post.data.series[1];
    
    if (!seriesMap.has(seriesName)) {
      seriesMap.set(seriesName, []);
    }
    
    const slug = getEntrySlug(post);
    seriesMap.get(seriesName).push({
      title: post.data.title,
      slug,
      href: getEntryHref(post),
      position: seriesPosition,
      date: post.data.date,
      description: post.data.description,
      image: post.data.image
    });
  }
});

// Sort each series by position
for (const posts of seriesMap.values()) {
  posts.sort((a: any, b: any) => {
    // First try to sort by position (if they're numbers)
    const posA = parseInt(a.position);
    const posB = parseInt(b.position);
    
    if (!isNaN(posA) && !isNaN(posB)) {
      return posA - posB;
    }
    
    // Fall back to string comparison of position
    if (a.position !== b.position) {
      return a.position.localeCompare(b.position);
    }
    
    // If positions are equal or not comparable, sort by date
    return new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime();
  });
}

// Convert map to array for easier template rendering
const seriesList = Array.from(seriesMap.entries()).map(([name, posts]) => ({
  name,
  posts,
  count: posts.length
}));

// Sort series by name
seriesList.sort((a, b) => a.name.localeCompare(b.name));

// Breadcrumbs for SEO
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Series', url: '/series/' }
];

const postTitleTransition = getTransitionAnimation('postTitles');
const postTitleTransitionAttrs = postTitleTransition
  ? { ["transition:animate"]: postTitleTransition }
  : {};
---

<Layout 
  title="Article Series | Bitdoze"
  description="Browse our collection of article series on various topics"
  breadcrumbs={breadcrumbs}
  hreflangs={[
    { lang: 'en', href: absoluteUrl('/series/', Astro.site || siteConfig.url) },
    { lang: 'es', href: absoluteUrl('/es/series/', Astro.site || siteConfig.url) },
    { lang: 'x-default', href: absoluteUrl('/series/', Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb Navigation -->
    <Breadcrumb items={breadcrumbs} className="mb-6" />
    
    <header class="mb-10 pb-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        Article Series
      </h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        Browse our collection of multi-part article series on various topics
      </p>
    </header>

    {seriesList.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No series available yet. Check back soon!</p>
      </div>
    ) : (
      <div class="space-y-8">
        {seriesList.map(series => (
          <div
            class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm transition-all duration-200 hover:shadow-md"
            {...postTitleTransitionAttrs}
          >
            <h2 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
              <Icon name="mdi:book-open-variant" class="w-6 h-6 text-blue-600 dark:text-blue-400 shrink-0" />
              {series.name}
              <span class="ml-auto text-xs font-semibold text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/40 px-3 py-1 rounded-full">
                {series.count} {series.count === 1 ? 'part' : 'parts'}
              </span>
            </h2>
            
            <div>
              <ol class="relative border-l border-gray-200 dark:border-gray-700 ml-4 space-y-6">
                {series.posts.map((post: any) => (
                  <li class="ml-6 relative">
                    <span class="absolute flex items-center justify-center w-7 h-7 bg-blue-600 text-white font-mono text-xs font-bold rounded-full -left-[39px] ring-4 ring-white dark:ring-gray-800">
                      {post.position}
                    </span>
                    <a 
                      href={post.href}
                      class="group block"
                    >
                      <h3
                        class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
                        transition:name={`post-title-${post.slug}`}
                        {...postTitleTransitionAttrs}
                      >
                        {post.title}
                      </h3>
                      {post.description && (
                        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 line-clamp-2 leading-relaxed">
                          {post.description}
                        </p>
                      )}
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
