---
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getLocaleFromPathname } from '@utils/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEs = locale === "es";
---

<Layout
  title={isEs ? "404 - Página no encontrada" : "404 - Page Not Found"}
  description={isEs ? "La página que buscas no existe." : "The page you're looking for doesn't exist."}
  lang={locale}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 flex flex-col items-center justify-center text-center">
    <div class="max-w-md bg-white dark:bg-gray-800 p-8 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
      <div class="w-16 h-16 rounded-full bg-blue-50 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 flex items-center justify-center mx-auto mb-6">
        <Icon name="mdi:alert-circle-outline" class="w-8 h-8" />
      </div>
      
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">
        404
      </h1>
      
      <h2 class="text-xl md:text-2xl font-bold text-gray-800 dark:text-gray-200 mb-4">
        {isEs ? "Página no encontrada" : "Page Not Found"}
      </h2>
      
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
        {isEs ? "La página que buscas no existe o ha sido trasladada." : "The page you're looking for doesn't exist or has been moved."}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a 
          href={isEs ? "/es/" : "/"} 
          class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all duration-200 font-semibold shadow-sm flex items-center justify-center gap-2"
        >
          <Icon name="mdi:home" class="w-4 h-4" />
          {isEs ? "Ir al inicio" : "Go Home"}
        </a>
        
        <a 
          href={isEs ? "/es/blog/" : "/blog/"} 
          class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 rounded-lg transition-all duration-200 font-semibold flex items-center justify-center gap-2"
        >
          <Icon name="mdi:book-open-variant" class="w-4 h-4" />
          {isEs ? "Ver el blog" : "Browse Blog"}
        </a>
      </div>
    </div>
  </div>
</Layout>
