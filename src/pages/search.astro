---
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "@config/site";
import { absoluteUrl } from "@utils/slugs";
---

<Layout
  title="Search - Bitdoze"
  description="Search for articles and tutorials on Bitdoze"
  noindex={true}
  hreflangs={[
    { lang: "en", href: absoluteUrl("/search/", Astro.site || siteConfig.url) },
    { lang: "es", href: absoluteUrl("/es/search/", Astro.site || siteConfig.url) },
    { lang: "x-default", href: absoluteUrl("/search/", Astro.site || siteConfig.url) },
  ]}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">Search</h1>
    <div id="search" data-pagefind-locale="en"></div>
  </div>
</Layout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    function initPagefind() {
      var el = document.getElementById("search");
      if (!el || el.dataset.pagefindInit === "true") return;
      el.dataset.pagefindInit = "true";

      var locale = el.dataset.pagefindLocale || "en";
      var script = document.createElement("script");
      script.src = "/pagefind/pagefind-ui.js";
      script.onerror = function () {
        el.innerHTML =
          '<p class="text-center text-gray-500">Search index is being built. Please try again later.</p>';
      };
      script.onload = function () {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: true,
            translations: {
              placeholder: "Search articles…",
            },
            // Filter to English posts via pagefind meta set in PostLayout
            filters: { locale: [locale] },
          });
        }
      };
      document.head.appendChild(script);
    }

    initPagefind();
    document.addEventListener("astro:page-load", initPagefind);
  })();
</script>
