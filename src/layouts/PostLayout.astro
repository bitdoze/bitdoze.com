---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "@layouts/Layout.astro";
import { formatDate } from "@utils/date";
import PostHeadings from "@components/table-of-contents/PostHeadings.astro";
import RelatedPosts from "@components/blog/RelatedPosts.astro";
import SocialShare from "@components/blog/SocialShare.astro";
import ServicesPromo from "@components/blog/ServicesPromo.astro";
import SeriesNav from "@components/widgets/SeriesNav.astro";
import ReadingProgress from "@components/blog/ReadingProgress.astro";
import Breadcrumb from "@components/common/Breadcrumb.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

import { getEntrySlug } from "@utils/content";
import { getLocaleBasePath, getPostLocale, getPostTranslationKey, isPostIdInLocale } from "@utils/i18n";
import { buildArchivePath, toTaxonomySlug } from "@utils/slugs";
import { getTransitionAnimation } from "@utils/view-transitions";
import { getRelatedPosts } from "@utils/relatedPosts";
import { getReadingTime } from "@utils/readingTime";
import { t } from "@i18n/ui";

interface Props {
  post: CollectionEntry<"posts">;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const { title, description, image, date, lastmod, categories, authors, tags } =
  post.data;
const imageAlt = post.data.imageAlt || title;
const postSlug = getEntrySlug(post);
const locale = getPostLocale(post);
const homePath = getLocaleBasePath(locale);
const blogPath = locale === "es" ? "/es/blog/" : "/blog/";
const postTitleTransition = getTransitionAnimation("postTitles");
const postImageTransition = getTransitionAnimation("postImages");
const postTitleTransitionAttrs = postTitleTransition
  ? { ["transition:animate"]: postTitleTransition }
  : {};
const postImageTransitionAttrs = postImageTransition
  ? { ["transition:animate"]: postImageTransition }
  : {};

// Get the canonical URL for this post
// Make sure we have a valid site URL to avoid the TypeError: Invalid URL error
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;

// Single collection fetch — filter in memory for locale, translations, related posts
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const allLocalePosts = allPosts.filter((p) => isPostIdInLocale(p.id, locale));

const postTranslationKey = getPostTranslationKey(post);
const translatedPosts = allPosts.filter(
  (entry) => getPostTranslationKey(entry) === postTranslationKey,
);

const hreflangs = translatedPosts.map((entry) => {
  const slug = getEntrySlug(entry);
  const entryLocale = getPostLocale(entry);
  const href = Astro.site ? new URL(`/${slug}/`, Astro.site).toString() : `/${slug}/`;

  return {
    lang: entryLocale,
    href,
  };
});

const defaultEntry = translatedPosts.find((entry) => getPostLocale(entry) === "en") || post;
const defaultHref = Astro.site
  ? new URL(`/${getEntrySlug(defaultEntry)}/`, Astro.site).toString()
  : `/${getEntrySlug(defaultEntry)}/`;
const seoHreflangs = [...hreflangs, { lang: "x-default", href: defaultHref }];

// Compute reading time
const readingTime = getReadingTime(post.body || "");
const readingTimeLabel = t(locale, "minRead");

// Look up author social links for structured data
const firstAuthor = authors && authors.length > 0 ? authors[0] : null;
let authorForSeo: { name: string; url?: string; sameAs?: string[] } | undefined;
let authorProfile: { name: string; image?: string; bio?: string; url: string } | undefined;
if (firstAuthor) {
  const allAuthors = await getCollection("authors");
  const authorEntry = allAuthors.find((a) => a.id === firstAuthor || a.data.title?.toLowerCase() === firstAuthor.toLowerCase());
  const authorArchiveUrl = buildArchivePath("authors", toTaxonomySlug(firstAuthor), locale);
  if (authorEntry) {
    authorProfile = {
      name: firstAuthor,
      image: authorEntry.data.image,
      bio: authorEntry.data.description,
      url: authorArchiveUrl,
    };
  } else {
    authorProfile = { name: firstAuthor, url: authorArchiveUrl };
  }
  const social = authorEntry?.data.social;
  const sameAs = social
    ? ([
        social.twitter,
        social.facebook,
        social.instagram,
        social.github,
        social.linkedin,
        social.youtube,
        social.website,
      ].filter((v): v is string => Boolean(v) && v !== "https://www.instagram.com/"))
    : undefined;
  const authorUrl = Astro.site
    ? new URL(buildArchivePath("authors", toTaxonomySlug(firstAuthor), locale), Astro.site).toString()
    : buildArchivePath("authors", toTaxonomySlug(firstAuthor), locale);
  authorForSeo = {
    name: firstAuthor,
    url: authorUrl,
    ...(sameAs && sameAs.length > 0 ? { sameAs } : {}),
  };
}

// Compute related posts once here and pass to both PostHeadings sidebar and RelatedPosts section
const otherLocalePosts = allLocalePosts.filter(p => getEntrySlug(p) !== postSlug);
const sidebarRelatedPosts = getRelatedPosts(post, otherLocalePosts, 3);

// Exclude sidebar picks so the bottom "Related Posts" section shows different articles
const sidebarRelatedSlugs = new Set(sidebarRelatedPosts.map((p) => getEntrySlug(p)));
const bottomRelatedPool = otherLocalePosts.filter(
  (p) => !sidebarRelatedSlugs.has(getEntrySlug(p)),
);

// Generate breadcrumbs for structured data
const breadcrumbs = [
  { name: locale === "es" ? "Inicio" : "Home", url: homePath },
  { name: locale === "es" ? "Blog" : "Blog", url: blogPath },
];

if (categories && categories.length > 0) {
  breadcrumbs.push({
    name: categories[0],
    url: buildArchivePath("categories", toTaxonomySlug(categories[0]), locale),
  });
}

breadcrumbs.push({ name: title, url: canonicalURL });
---

<Layout
  title={title}
  description={description}
  image={image.src}
  article={true}
  canonical={canonicalURL}
  lang={locale}
  hreflangs={seoHreflangs}
  publishDate={date}
  modifiedDate={lastmod}
  author={authorForSeo}
  tags={tags}
  categories={categories}
  breadcrumbs={breadcrumbs}
  wideContent={true}
>
  <!-- Reading Progress Bar -->
  <ReadingProgress />

  <article
    class="w-full py-8"
    style="transition: opacity 0.3s ease;"
    data-pagefind-body
    data-pagefind-meta={`locale:${locale}`}
    data-pagefind-filter={`locale:${locale}`}
  >
    <!-- Content + right-rail TOC grid; the rail only exists at xl and up -->
    <div
      class="mx-auto max-w-3xl xl:max-w-[64rem] 2xl:max-w-[68rem] px-4 sm:px-6 xl:grid xl:grid-cols-[minmax(0,1fr)_16rem] 2xl:grid-cols-[minmax(0,1fr)_18rem] xl:gap-12"
    >
      <div class="min-w-0">
        <!-- Breadcrumb Navigation -->
        <Breadcrumb items={breadcrumbs} className="mb-6" />

        <!-- Post Header -->
        <header class="mb-10">
          <!-- Category kicker -->
          {
            categories && categories.length > 0 && (
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-4 text-sm font-semibold">
                {categories.map((category: string, index: number) => (
                  <>
                    <a
                      href={buildArchivePath("categories", toTaxonomySlug(category), locale)}
                      class="text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                    >
                      {category}
                    </a>
                    {index < categories.length - 1 && (
                      <span class="text-gray-300 dark:text-gray-600">/</span>
                    )}
                  </>
                ))}
              </div>
            )
          }

          <!-- Title -->
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-tight text-balance text-gray-900 dark:text-white"
            transition:name={`post-title-${postSlug}`}
            {...postTitleTransitionAttrs}
          >
            {title}
          </h1>

          <!-- Description lede callout -->
          {
            description && (
              <div class="mt-6 rounded-xl border border-blue-100 bg-blue-50/60 px-5 py-4 dark:border-blue-900/60 dark:bg-blue-950/30">
                <p class="text-lg leading-relaxed text-pretty text-gray-700 dark:text-gray-200">
                  {description}
                </p>
              </div>
            )
          }

          <!-- Meta line -->
          <div
            class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-500 dark:text-gray-400"
          >
            {
              authorProfile && (
                <a
                  href={authorProfile.url}
                  class="group inline-flex items-center gap-2 font-medium text-gray-700 transition-colors duration-200 hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400"
                >
                  {authorProfile.image && (
                    <img
                      src={authorProfile.image}
                      alt={authorProfile.name}
                      width="28"
                      height="28"
                      loading="lazy"
                      class="h-7 w-7 rounded-full object-cover ring-1 ring-gray-200 dark:ring-gray-700"
                    />
                  )}
                  {authorProfile.name}
                </a>
              )
            }
            {
              date && (
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="mdi:calendar" class="w-4 h-4" />
                  <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
                </span>
              )
            }
            {
              lastmod && (!date || lastmod.toDateString() !== date.toDateString()) && (
                <span
                  class="inline-flex items-center gap-1.5"
                  title={locale === "es" ? "Ultima actualizacion" : "Last updated"}
                >
                  <Icon name="mdi:update" class="w-4 h-4 text-blue-500 dark:text-blue-400" />
                  {locale === "es" ? "Actualizado" : "Updated"}
                  <time datetime={lastmod.toISOString()}>{formatDate(lastmod, locale)}</time>
                </span>
              )
            }
            <span class="inline-flex items-center gap-1.5">
              <Icon name="mdi:clock-outline" class="w-4 h-4" />
              {readingTime.minutes > 0 ? readingTime.minutes : 1} {readingTimeLabel}
            </span>
          </div>

          <!-- Featured Image -->
          {
            image && (
              <div class="mt-8 overflow-hidden rounded-lg border border-gray-200 shadow-sm aspect-video dark:border-gray-700">
                <Image
                  src={image}
                  alt={imageAlt}
                  class="w-full h-full object-cover"
                  width={1280}
                  height={720}
                  loading="eager"
                  fetchpriority="high"
                  sizes="(max-width: 1280px) calc(100vw - 2rem), (max-width: 1536px) 720px, 752px"
                  widths={[480, 768, 1024, 1280]}
                  format="webp"
                  quality={80}
                  transition:name={`post-image-${postSlug}`}
                  {...postImageTransitionAttrs}
                />
              </div>
            )
          }
        </header>

        <!-- Series Navigation (if part of a series) -->
        {
          post.data.series &&
            Array.isArray(post.data.series) &&
            post.data.series.length === 2 && (
              <SeriesNav
                currentSlug={postSlug}
                seriesName={post.data.series[0]}
                seriesPosition={post.data.series[1]}
              />
            )
        }

        <!-- Post Content -->
        <div
          class="prose prose-lg dark:prose-invert prose-blue prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-lg w-full max-w-none!"
          style="min-height: 200px;"
        >
          <slot />
        </div>

        <!-- Tags (end of article) -->
        {
          tags && tags.length > 0 && (
            <div class="mt-10 flex flex-wrap gap-2 border-t border-gray-200 pt-6 dark:border-gray-700">
              {tags.map((tag: string) => (
                <a
                  href={buildArchivePath("tags", toTaxonomySlug(tag), locale)}
                  class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-100 hover:text-blue-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-blue-900 dark:hover:text-blue-300"
                >
                  #{tag.charAt(0).toUpperCase() + tag.slice(1)}
                </a>
              ))}
            </div>
          )
        }

        <!-- Author byline -->
        {
          authorProfile && (
            <aside class="not-prose mt-8 flex items-start gap-4 rounded-lg border border-gray-200 bg-gray-50 p-5 dark:border-gray-700 dark:bg-gray-800/50">
              {authorProfile.image && (
                <img
                  src={authorProfile.image}
                  alt={authorProfile.name}
                  width="48"
                  height="48"
                  loading="lazy"
                  class="h-12 w-12 shrink-0 rounded-full object-cover ring-1 ring-gray-200 dark:ring-gray-700"
                />
              )}
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  {locale === "es" ? "Escrito por" : "Written by"}{" "}
                  <a
                    href={authorProfile.url}
                    class="text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                  >
                    {authorProfile.name}
                  </a>
                </p>
                {authorProfile.bio && (
                  <p class="mt-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400 line-clamp-3">
                    {authorProfile.bio}
                  </p>
                )}
                <a
                  href={authorProfile.url}
                  class="group mt-2 inline-flex items-center gap-1 text-sm font-medium text-blue-600 transition-colors duration-200 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                >
                  {locale === "es" ? `Mas guias de ${authorProfile.name}` : `More guides from ${authorProfile.name}`}
                  <Icon
                    name="mdi:arrow-right"
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5"
                  />
                </a>
              </div>
            </aside>
          )
        }

        <ServicesPromo locale={locale} />

        <!-- Social Share Component -->
        <SocialShare title={title} description={description} url={canonicalURL} locale={locale} />

        <!-- Related Posts (excludes the ones already shown in the sidebar) -->
        <RelatedPosts currentPost={post} preloadedPosts={bottomRelatedPool} />
      </div>

      <!-- Right rail: sticky TOC + related (xl and up) -->
      <PostHeadings headings={headings} currentPost={post} relatedPosts={sidebarRelatedPosts} />
    </div>
  </article>

  <!-- Code block copy buttons -->
  <script>
    (() => {
      const win = window as typeof window & { __bitdozeCodeCopyBooted?: boolean };
      const copyIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const checkIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

      async function copyText(text: string): Promise<boolean> {
        if (typeof navigator !== "undefined" && navigator.clipboard?.writeText) {
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch {
            // Fall through to execCommand fallback (permissions / insecure context)
          }
        }

        try {
          const textarea = document.createElement("textarea");
          textarea.value = text;
          textarea.setAttribute("readonly", "");
          textarea.style.position = "fixed";
          textarea.style.top = "0";
          textarea.style.left = "0";
          textarea.style.width = "1px";
          textarea.style.height = "1px";
          textarea.style.padding = "0";
          textarea.style.border = "none";
          textarea.style.outline = "none";
          textarea.style.boxShadow = "none";
          textarea.style.background = "transparent";
          textarea.style.opacity = "0";
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          textarea.setSelectionRange(0, text.length);
          const ok = document.execCommand("copy");
          document.body.removeChild(textarea);
          return ok;
        } catch {
          return false;
        }
      }

      function setButtonState(
        btn: HTMLButtonElement,
        state: "idle" | "copied" | "error",
      ) {
        btn.classList.remove("copied", "copy-error");
        if (state === "copied") {
          btn.classList.add("copied");
          btn.innerHTML = checkIcon;
          btn.setAttribute("aria-label", "Copied");
        } else if (state === "error") {
          btn.classList.add("copy-error");
          btn.innerHTML = copyIcon;
          btn.setAttribute("aria-label", "Copy failed");
        } else {
          btn.innerHTML = copyIcon;
          btn.setAttribute("aria-label", "Copy code");
        }
      }

      function initCodeCopy() {
        const codeBlocks = document.querySelectorAll(".prose pre");
        codeBlocks.forEach((pre) => {
          if (!(pre instanceof HTMLElement)) return;
          if (pre.parentElement?.classList.contains("code-copy-wrapper")) return;

          const wrapper = document.createElement("div");
          wrapper.className = "code-copy-wrapper";
          pre.parentNode!.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const btn = document.createElement("button");
          btn.className = "code-copy-btn";
          btn.type = "button";
          setButtonState(btn, "idle");
          btn.addEventListener("click", async (event) => {
            event.preventDefault();
            event.stopPropagation();
            const code = pre.querySelector("code");
            const text = code?.textContent || pre.textContent || "";
            if (!text) {
              setButtonState(btn, "error");
              setTimeout(() => setButtonState(btn, "idle"), 2000);
              return;
            }
            const ok = await copyText(text);
            setButtonState(btn, ok ? "copied" : "error");
            setTimeout(() => setButtonState(btn, "idle"), 2000);
          });
          wrapper.appendChild(btn);
        });
      }

      if (!win.__bitdozeCodeCopyBooted) {
        win.__bitdozeCodeCopyBooted = true;
        document.addEventListener("astro:page-load", initCodeCopy);
        document.addEventListener("astro:after-swap", initCodeCopy);
      }
      initCodeCopy();
    })();
  </script>

  <style is:global>
    .code-copy-wrapper {
      position: relative;
    }
    .code-copy-btn {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.375rem;
      background: rgba(0, 0, 0, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 0.375rem;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      /* Always visible enough on touch; stronger on hover/focus */
      opacity: 0.85;
      transition: opacity 0.2s, background 0.2s;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    @media (hover: hover) and (pointer: fine) {
      .code-copy-btn {
        opacity: 0;
      }
      .code-copy-wrapper:hover .code-copy-btn,
      .code-copy-btn:focus,
      .code-copy-btn:focus-visible,
      .code-copy-btn.copied {
        opacity: 1;
      }
    }
    .code-copy-btn:hover {
      background: rgba(0, 0, 0, 0.65);
      color: #fff;
    }
    .code-copy-btn.copied {
      color: #4ade80;
      opacity: 1;
    }
    .code-copy-btn.copy-error {
      color: #f87171;
      opacity: 1;
    }
    .code-copy-btn:focus-visible {
      outline: 2px solid #3b82f6;
      outline-offset: 2px;
      opacity: 1;
    }
  </style>
</Layout>
