---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "@layouts/Layout.astro";
import { formatDate } from "@utils/date";
import PostHeadings from "@components/table-of-contents/PostHeadings.astro";
import RelatedPosts from "@components/blog/RelatedPosts.astro";
import SocialShare from "@components/blog/SocialShare.astro";
import ServicesPromo from "@components/blog/ServicesPromo.astro";
import SeriesNav from "@components/widgets/SeriesNav.astro";
import ReadingProgress from "@components/blog/ReadingProgress.astro";
import Breadcrumb from "@components/common/Breadcrumb.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

import { getEntrySlug } from "@utils/content";
import { getLocaleBasePath, getPostLocale, getPostTranslationKey, isPostIdInLocale } from "@utils/i18n";
import { buildArchivePath, toTaxonomySlug } from "@utils/slugs";
import { getTransitionAnimation } from "@utils/view-transitions";
import { getRelatedPosts } from "@utils/relatedPosts";
import { getReadingTime } from "@utils/readingTime";
import { t } from "@i18n/ui";

interface Props {
  post: CollectionEntry<"posts">;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const { title, description, image, date, lastmod, categories, authors, tags } =
  post.data;
const imageAlt = post.data.imageAlt || title;
const postSlug = getEntrySlug(post);
const locale = getPostLocale(post);
const homePath = getLocaleBasePath(locale);
const blogPath = locale === "es" ? "/es/blog/" : "/blog/";
const postTitleTransition = getTransitionAnimation("postTitles");
const postImageTransition = getTransitionAnimation("postImages");
const postTitleTransitionAttrs = postTitleTransition
  ? { ["transition:animate"]: postTitleTransition }
  : {};
const postImageTransitionAttrs = postImageTransition
  ? { ["transition:animate"]: postImageTransition }
  : {};

// Get the canonical URL for this post
// Make sure we have a valid site URL to avoid the TypeError: Invalid URL error
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;

// Single collection fetch — filter in memory for locale, translations, related posts
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const allLocalePosts = allPosts.filter((p) => isPostIdInLocale(p.id, locale));

const postTranslationKey = getPostTranslationKey(post);
const translatedPosts = allPosts.filter(
  (entry) => getPostTranslationKey(entry) === postTranslationKey,
);

const hreflangs = translatedPosts.map((entry) => {
  const slug = getEntrySlug(entry);
  const entryLocale = getPostLocale(entry);
  const href = Astro.site ? new URL(`/${slug}/`, Astro.site).toString() : `/${slug}/`;

  return {
    lang: entryLocale,
    href,
  };
});

const defaultEntry = translatedPosts.find((entry) => getPostLocale(entry) === "en") || post;
const defaultHref = Astro.site
  ? new URL(`/${getEntrySlug(defaultEntry)}/`, Astro.site).toString()
  : `/${getEntrySlug(defaultEntry)}/`;
const seoHreflangs = [...hreflangs, { lang: "x-default", href: defaultHref }];

// Compute reading time
const readingTime = getReadingTime(post.body || "");
const readingTimeLabel = t(locale, "minRead");

// Look up author social links for structured data
const firstAuthor = authors && authors.length > 0 ? authors[0] : null;
let authorForSeo: { name: string; url?: string; sameAs?: string[] } | undefined;
if (firstAuthor) {
  const allAuthors = await getCollection("authors");
  const authorEntry = allAuthors.find((a) => a.id === firstAuthor || a.data.title?.toLowerCase() === firstAuthor.toLowerCase());
  const social = authorEntry?.data.social;
  const sameAs = social
    ? ([
        social.twitter,
        social.facebook,
        social.instagram,
        social.github,
        social.linkedin,
        social.youtube,
        social.website,
      ].filter((v): v is string => Boolean(v) && v !== "https://www.instagram.com/"))
    : undefined;
  const authorUrl = Astro.site
    ? new URL(buildArchivePath("authors", toTaxonomySlug(firstAuthor), locale), Astro.site).toString()
    : buildArchivePath("authors", toTaxonomySlug(firstAuthor), locale);
  authorForSeo = {
    name: firstAuthor,
    url: authorUrl,
    ...(sameAs && sameAs.length > 0 ? { sameAs } : {}),
  };
}

// Compute related posts once here and pass to both PostHeadings sidebar and RelatedPosts section
const otherLocalePosts = allLocalePosts.filter(p => getEntrySlug(p) !== postSlug);
const sidebarRelatedPosts = getRelatedPosts(post, otherLocalePosts, 3);

// Generate breadcrumbs for structured data
const breadcrumbs = [
  { name: locale === "es" ? "Inicio" : "Home", url: homePath },
  { name: locale === "es" ? "Blog" : "Blog", url: blogPath },
];

if (categories && categories.length > 0) {
  breadcrumbs.push({
    name: categories[0],
    url: buildArchivePath("categories", toTaxonomySlug(categories[0]), locale),
  });
}

breadcrumbs.push({ name: title, url: canonicalURL });
---

<Layout
  title={title}
  description={description}
  image={image.src}
  article={true}
  canonical={canonicalURL}
  lang={locale}
  hreflangs={seoHreflangs}
  publishDate={date}
  modifiedDate={lastmod}
  author={authorForSeo}
  tags={tags}
  categories={categories}
  breadcrumbs={breadcrumbs}
>
  <!-- Reading Progress Bar -->
  <ReadingProgress />

  <article
    class="w-full py-8"
    style="transition: opacity 0.3s ease;"
    data-pagefind-body
    data-pagefind-meta={`locale:${locale}`}
    data-pagefind-filter={`locale:${locale}`}
  >
    <!-- Breadcrumb Navigation -->
    <Breadcrumb items={breadcrumbs} className="mb-6" />

    <!-- Post Header -->
    <header class="mb-8">
      <div
        class="flex flex-wrap items-center text-gray-500 dark:text-gray-400 mb-4 gap-4"
      >
        <!-- Date -->
        <div class="flex items-center">
          <Icon name="mdi:calendar" class="w-5 h-5 mr-1" />
          <time datetime={date?.toISOString()}>
            {date ? formatDate(date, locale) : ""}
          </time>
        </div>

        <!-- Reading Time -->
        <div class="flex items-center">
          <Icon name="mdi:clock-outline" class="w-5 h-5 mr-1" />
          <span>{readingTime.minutes > 0 ? readingTime.minutes : 1} {readingTimeLabel}</span>
        </div>

        <!-- Categories -->
        {
          categories && categories.length > 0 && (
            <div class="flex items-center">
              <Icon name="mdi:folder" class="w-5 h-5 mr-1" />
              <div class="flex flex-wrap gap-2">
                {categories.map((category: string, index: number) => (
                  <>
                    <a
                      href={buildArchivePath("categories", toTaxonomySlug(category), locale)}
                      class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300"
                    >
                      {category}
                    </a>
                    {index < categories.length - 1 && (
                      <span class="text-gray-400">,</span>
                    )}
                  </>
                ))}
              </div>
            </div>
          )
        }

        <!-- Author -->
        {
          authors && authors.length > 0 && (
            <div class="flex items-center">
              <Icon name="mdi:account" class="w-5 h-5 mr-1" />
              <div class="flex flex-wrap gap-2">
                {authors.map((author: string) => (
                  <a
                    href={buildArchivePath("authors", toTaxonomySlug(author), locale)}
                    class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300"
                  >
                    {author}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <!-- Title -->
      <h1
        class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
        transition:name={`post-title-${postSlug}`}
        {...postTitleTransitionAttrs}
      >
        {title}
      </h1>

      <!-- Description -->
      {
        description && (
          <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            {description}
          </p>
        )
      }

      <!-- Featured Image -->
      {
        image && (
          <div class="rounded-lg overflow-hidden mb-8 aspect-video">
            <Image
              src={image}
              alt={imageAlt}
              class="w-full h-full object-cover"
              width={1280}
              height={720}
              loading="eager"
              fetchpriority="high"
              sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, 1280px"
              widths={[480, 768, 1024, 1280]}
              format="webp"
              quality={80}
              transition:name={`post-image-${postSlug}`}
              {...postImageTransitionAttrs}
            />
          </div>
        )
      }

      <!-- Tags -->
      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map((tag: string) => (
              <a
                href={buildArchivePath("tags", toTaxonomySlug(tag), locale)}
                class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm hover:bg-blue-100 dark:hover:bg-blue-900 transition-colors duration-300"
              >
                #{tag.charAt(0).toUpperCase() + tag.slice(1)}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- Series Navigation (if part of a series) -->
    {
      post.data.series &&
        Array.isArray(post.data.series) &&
        post.data.series.length === 2 && (
          <SeriesNav
            currentSlug={postSlug}
            seriesName={post.data.series[0]}
            seriesPosition={post.data.series[1]}
          />
        )
    }

    <!-- Table of Contents -->
    <PostHeadings headings={headings} currentPost={post} relatedPosts={sidebarRelatedPosts} />

    <!-- Post Content -->
    <div
      class="prose prose-lg dark:prose-invert prose-blue prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-lg w-full max-w-none!"
      style="min-height: 200px;"
    >
      <slot />
    </div>

    <ServicesPromo locale={locale} />

    <!-- Social Share Component -->
    <SocialShare title={title} description={description} url={canonicalURL} locale={locale} />

    <!-- Related Posts -->
    <RelatedPosts currentPost={post} preloadedPosts={otherLocalePosts} />
  </article>

  <!-- Code block copy buttons -->
  <script>
    (() => {
      const win = window as typeof window & { __bitdozeCodeCopyBooted?: boolean };
      const copyIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const checkIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

      function initCodeCopy() {
        const codeBlocks = document.querySelectorAll(".prose pre");
        codeBlocks.forEach((pre) => {
          if (pre.parentElement?.classList.contains("code-copy-wrapper")) return;

          const wrapper = document.createElement("div");
          wrapper.className = "code-copy-wrapper";
          pre.parentNode!.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const btn = document.createElement("button");
          btn.className = "code-copy-btn";
          btn.type = "button";
          btn.setAttribute("aria-label", "Copy code");
          btn.innerHTML = copyIcon;
          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code");
            const text = code?.textContent || pre.textContent || "";
            try {
              await navigator.clipboard.writeText(text);
              btn.classList.add("copied");
              btn.innerHTML = checkIcon;
              setTimeout(() => {
                btn.classList.remove("copied");
                btn.innerHTML = copyIcon;
              }, 2000);
            } catch (_) {}
          });
          wrapper.appendChild(btn);
        });
      }

      if (!win.__bitdozeCodeCopyBooted) {
        win.__bitdozeCodeCopyBooted = true;
        document.addEventListener("astro:page-load", initCodeCopy);
      }
      initCodeCopy();
    })();
  </script>

  <style is:global>
    .code-copy-wrapper {
      position: relative;
    }
    .code-copy-btn {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      padding: 0.375rem;
      background: rgba(0, 0, 0, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 0.375rem;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      /* Always visible enough on touch; stronger on hover/focus */
      opacity: 0.85;
      transition: opacity 0.2s, background 0.2s;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    @media (hover: hover) and (pointer: fine) {
      .code-copy-btn {
        opacity: 0;
      }
      .code-copy-wrapper:hover .code-copy-btn,
      .code-copy-btn:focus,
      .code-copy-btn:focus-visible,
      .code-copy-btn.copied {
        opacity: 1;
      }
    }
    .code-copy-btn:hover {
      background: rgba(0, 0, 0, 0.65);
      color: #fff;
    }
    .code-copy-btn.copied {
      color: #4ade80;
      opacity: 1;
    }
    .code-copy-btn:focus-visible {
      outline: 2px solid #3b82f6;
      outline-offset: 2px;
      opacity: 1;
    }
  </style>
</Layout>
