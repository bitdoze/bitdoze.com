---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Accordion from "@components/widgets/Accordion.astro";
import {
  getServicesContactHref,
  getServicesIndexPath,
  type ServiceConfig,
  type ServiceLocale,
} from "@config/services";
import { getEntrySlug, getEntryHref } from "@utils/content";
import { getPostLocale, getPostTranslationKey } from "@utils/i18n";

interface Props {
  locale: ServiceLocale;
  service: ServiceConfig;
}

const { locale, service } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const servicesIndexPath = getServicesIndexPath(locale);
const contactHref = getServicesContactHref(locale);

const serviceArticles = service.relatedArticles.flatMap((reference) => {
    const defaultPost = allPosts.find((post) => getEntrySlug(post) === reference.slug);
    if (!defaultPost) return [];

    const translationKey = getPostTranslationKey(defaultPost);
    const localizedPost =
      allPosts.find(
        (post) =>
          getPostTranslationKey(post) === translationKey &&
          getPostLocale(post) === locale,
      ) || defaultPost;

    return {
      title: localizedPost.data.title,
      description: localizedPost.data.description,
      href: getEntryHref(localizedPost),
    };
  });
---

<main class="w-full">
  <section class="relative overflow-hidden bg-white dark:bg-gray-900">
    <div class="absolute inset-0 pointer-events-none">
      <div class={`absolute left-0 top-0 h-72 w-72 rounded-full bg-linear-to-br ${service.accent} opacity-15 blur-3xl`}></div>
      <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-blue-200/30 blur-3xl dark:bg-blue-500/10"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <a
        href={getServicesIndexPath(locale)}
        class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition-colors hover:text-blue-700 dark:text-blue-300 dark:hover:text-blue-200"
      >
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        {locale === "es" ? "Volver a servicios" : "Back to services"}
      </a>

      <div class="mt-6 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div>
          <div class={`inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-linear-to-br ${service.accent} text-white shadow-xl`}>
            <Icon name={service.icon} class="h-8 w-8" />
          </div>
          <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl">
            {service.title[locale]}
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-gray-600 dark:text-gray-300">
            {service.heroDescription[locale]}
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href={contactHref}
              class={`inline-flex items-center justify-center gap-2 rounded-xl bg-linear-to-r ${service.accent} px-7 py-4 text-base font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl`}
            >
              <Icon name="mdi:email-fast-outline" class="h-5 w-5" />
              {locale === "es" ? "Hablar sobre este servicio" : "Talk about this service"}
            </a>
            <a
              href="#scope"
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-7 py-4 text-base font-semibold text-gray-800 transition-colors hover:border-blue-300 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:hover:border-blue-700 dark:hover:text-blue-300"
            >
              <Icon name="mdi:format-list-bulleted-square" class="h-5 w-5" />
              {locale === "es" ? "Ver alcance" : "View scope"}
            </a>
          </div>
        </div>

        <aside class="rounded-3xl border border-gray-200 bg-gray-50 p-8 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">
            {locale === "es" ? "Ideal para" : "Best fit for"}
          </h2>
          <ul class="mt-5 space-y-4">
            {service.idealFor[locale].map((item) => (
              <li class="flex items-start gap-3 text-sm leading-7 text-gray-700 dark:text-gray-300">
                <Icon name="mdi:check-circle-outline" class="mt-1 h-5 w-5 shrink-0 text-blue-600 dark:text-blue-300" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section id="scope" class="scroll-mt-24 bg-gray-50 py-16 dark:bg-gray-800/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
            {locale === "es" ? "Que incluye" : "What this includes"}
          </h2>
          <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
            {service.intro[locale]}
          </p>

          <div class="mt-8 grid gap-5">
            {service.deliverables.map((item) => (
              <div class="rounded-2xl border border-gray-200 p-5 dark:border-gray-700">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.title[locale]}</h3>
                <p class="mt-2 text-sm leading-7 text-gray-600 dark:text-gray-300">{item.description[locale]}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-8">
          <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-900">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
              {locale === "es" ? "Proceso" : "Process"}
            </h2>
            <div class="mt-6 space-y-5">
              {service.process[locale].map((step, index) => (
                <div class="flex gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gray-900 text-sm font-bold text-white dark:bg-white dark:text-gray-900">
                    {index + 1}
                  </div>
                  <p class="pt-1 text-sm leading-7 text-gray-600 dark:text-gray-300">{step}</p>
                </div>
              ))}
            </div>
          </div>

          <div class={`rounded-3xl bg-linear-to-br ${service.accent} p-8 text-white shadow-xl`}>
            <h2 class="text-2xl font-bold">
              {locale === "es" ? "Resultado esperado" : "Likely outcome"}
            </h2>
            <ul class="mt-5 space-y-4">
              {service.outcomes[locale].map((item) => (
                <li class="flex items-start gap-3 text-sm leading-7 text-white/95">
                  <Icon name="mdi:check-bold" class="mt-1 h-5 w-5 shrink-0" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-300">
            {locale === "es" ? "Prueba de trabajo" : "Relevant work"}
          </p>
          <h2 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white">
            {locale === "es" ? "Articulos relacionados" : "Related articles"}
          </h2>
        </div>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {serviceArticles.map((article) => (
          <a
            href={article.href}
            class="group flex h-full flex-col rounded-3xl border border-gray-200 bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-300 hover:bg-white hover:shadow-lg dark:border-gray-700 dark:bg-gray-800 dark:hover:border-blue-700 dark:hover:bg-gray-900"
          >
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 dark:bg-blue-950/40 dark:text-blue-300">
              <Icon name="mdi:file-document-outline" class="h-5 w-5" />
            </div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900 transition-colors group-hover:text-blue-700 dark:text-white dark:group-hover:text-blue-300">
              {article.title}
            </h3>
            <p class="mt-3 grow text-sm leading-7 text-gray-600 dark:text-gray-300">{article.description}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-blue-600 dark:text-blue-300">
              {locale === "es" ? "Leer articulo" : "Read article"}
              <Icon name="mdi:arrow-right" class="h-4 w-4" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16 dark:bg-gray-800/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="rounded-3xl bg-gray-900 p-8 text-white shadow-xl dark:bg-gray-950">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-200">
            {locale === "es" ? "CTA" : "CTA"}
          </p>
          <h2 class="mt-4 text-3xl font-bold">
            {locale === "es" ? "Si esto encaja con tu proyecto, escribeme" : "If this matches your project, reach out"}
          </h2>
          <p class="mt-4 text-base leading-8 text-gray-200">
            {locale === "es"
              ? "Por ahora los enlaces de contacto siguen como placeholder, pero la pagina ya marca el tipo de trabajo y el encaje esperado."
              : "The contact links are placeholders for now, but this page already defines the kind of work and fit clearly."}
          </p>
          <div class="mt-8 flex flex-col gap-3">
            <a
              href={contactHref}
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition-colors hover:bg-blue-50"
            >
              <Icon name="mdi:send-outline" class="h-5 w-5" />
              {locale === "es" ? "Contactar" : "Contact"}
            </a>
            <a
              href={servicesIndexPath}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
            >
              <Icon name="mdi:view-grid-outline" class="h-5 w-5" />
              {locale === "es" ? "Ver todos los servicios" : "See all services"}
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
            {locale === "es" ? "Preguntas frecuentes" : "Frequently asked questions"}
          </h2>
          <div class="mt-8 space-y-4">
            {service.faq.map((item, index) => (
              <Accordion
                label={item.question[locale]}
                group={`service-${service.key}-${locale}`}
                expanded={index === 0 ? "true" : "false"}
              >
                <p class="text-gray-600 dark:text-gray-300 leading-8">{item.answer[locale]}</p>
              </Accordion>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
