---
import { Icon } from "astro-icon/components";
import Accordion from "@components/widgets/Accordion.astro";
import {
  getServicesContactHref,
  getServicePath,
  getServices,
  getServicesIndexPath,
  servicesPageCopy,
  type ServiceLocale,
} from "@config/services";

interface Props {
  locale: ServiceLocale;
}

const { locale } = Astro.props;
const services = getServices(locale);
const copy = servicesPageCopy;
const servicesIndexPath = getServicesIndexPath(locale);
const contactHref = getServicesContactHref(locale);
---

<main class="w-full">
  <section class="relative overflow-hidden bg-white dark:bg-gray-900">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-blue-200/40 blur-3xl dark:bg-blue-500/15"></div>
      <div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-cyan-200/40 blur-3xl dark:bg-cyan-500/10"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-4xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 dark:border-blue-900/60 dark:bg-blue-950/40 dark:text-blue-300">
          <Icon name="mdi:briefcase-outline" class="h-4 w-4" />
          {copy.badge[locale]}
        </span>
        <h1 class="mt-6 max-w-4xl text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl lg:text-6xl">
          {copy.title[locale]}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-gray-600 dark:text-gray-300">
          {copy.description[locale]}
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href={contactHref}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-linear-to-r from-blue-500 to-indigo-500 px-7 py-4 text-base font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-600 hover:to-indigo-600 hover:shadow-xl"
          >
            <Icon name="mdi:email-fast-outline" class="h-5 w-5" />
            {copy.primaryCta[locale]}
          </a>
          <a
            href="#service-areas"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-7 py-4 text-base font-semibold text-gray-800 transition-all duration-300 hover:border-blue-300 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:hover:border-blue-700 dark:hover:text-blue-300"
          >
            <Icon name="mdi:view-grid-outline" class="h-5 w-5" />
            {copy.secondaryCta[locale]}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12 dark:bg-gray-800/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid gap-6 md:grid-cols-3">
        {[
          {
            icon: "mdi:file-document-multiple-outline",
            title: locale === "es" ? "Basado en experiencia publicada" : "Backed by published work",
            text: locale === "es"
              ? "Las paginas enlazan con guias reales del sitio, no con promesas genericas."
              : "These pages connect directly to real guides already published on the site.",
          },
          {
            icon: "mdi:cog-outline",
            title: locale === "es" ? "Enfoque tecnico y practico" : "Technical and practical",
            text: locale === "es"
              ? "El foco esta en setups, despliegues y estructura que puedas seguir usando."
              : "The focus is on setups, deployments, and structure you can keep operating.",
          },
          {
            icon: "mdi:shape-outline",
            title: locale === "es" ? "Servicios combinables" : "Services can be combined",
            text: locale === "es"
              ? "Un proyecto puede mezclar Astro, VPS, Dokploy y apps self-hosted."
              : "A project can combine Astro, VPS, Dokploy, and self-hosted app work.",
          },
        ].map((item) => (
          <div class="rounded-2xl border border-white/80 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-900">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600 dark:bg-blue-950/40 dark:text-blue-300">
              <Icon name={item.icon} class="h-6 w-6" />
            </div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">{item.title}</h2>
            <p class="mt-2 text-sm leading-7 text-gray-600 dark:text-gray-300">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="service-areas" class="scroll-mt-24 bg-white py-16 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-300">{copy.trustLabel[locale]}</p>
        <h2 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">{copy.sectionTitle[locale]}</h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">{copy.sectionDescription[locale]}</p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {services.map((service, index) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-gray-200 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
            style={`animation-delay: ${index * 80}ms;`}
          >
            <div class={`absolute inset-x-0 top-0 h-1 bg-linear-to-r ${service.accent}`}></div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-linear-to-br ${service.accent} text-white shadow-lg`}>
                  <Icon name={service.icon} class="h-7 w-7" />
                </div>
                <h3 class="mt-5 text-2xl font-bold text-gray-900 dark:text-white">{service.title[locale]}</h3>
                <p class="mt-3 text-base leading-8 text-gray-600 dark:text-gray-300">{service.shortDescription[locale]}</p>
              </div>
            </div>

            <ul class="mt-6 space-y-3">
              {service.idealFor[locale].slice(0, 3).map((item) => (
                <li class="flex items-start gap-3 text-sm leading-7 text-gray-700 dark:text-gray-300">
                  <Icon name="mdi:check-circle-outline" class="mt-1 h-5 w-5 shrink-0 text-blue-600 dark:text-blue-300" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
              <a
                href={getServicePath(service, locale)}
                class="inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-600 dark:bg-white dark:text-gray-900 dark:hover:bg-blue-300"
              >
                <Icon name="mdi:arrow-right" class="h-5 w-5" />
                {locale === "es" ? "Ver servicio" : "View service"}
              </a>
              <a
                href={contactHref}
                class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-200 px-5 py-3 text-sm font-semibold text-gray-700 transition-colors hover:border-blue-300 hover:text-blue-700 dark:border-gray-700 dark:text-gray-200 dark:hover:border-blue-700 dark:hover:text-blue-300"
              >
                <Icon name="mdi:message-text-fast-outline" class="h-5 w-5" />
                {locale === "es" ? "Consultar" : "Ask about it"}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16 dark:bg-gray-800/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">{copy.processTitle[locale]}</h2>
          <div class="mt-8 space-y-5">
            {copy.processSteps[locale].map((step, index) => (
              <div class="flex gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                  {index + 1}
                </div>
                <p class="pt-1 text-base leading-8 text-gray-600 dark:text-gray-300">{step}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-3xl bg-linear-to-br from-gray-900 via-slate-900 to-blue-900 p-8 text-white shadow-xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-200">
            {locale === "es" ? "Siguiente paso" : "Next step"}
          </p>
          <h2 class="mt-4 text-3xl font-bold">
            {copy.ctaTitle[locale]}
          </h2>
          <p class="mt-4 text-base leading-8 text-blue-50/90">
            {copy.ctaDescription[locale]}
          </p>
          <div class="mt-8 flex flex-col gap-3">
            <a
              href={contactHref}
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition-colors hover:bg-blue-50"
            >
              <Icon name="mdi:send-outline" class="h-5 w-5" />
              {copy.primaryCta[locale]}
            </a>
            <a
              href={servicesIndexPath}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
            >
              <Icon name="mdi:view-grid-outline" class="h-5 w-5" />
              {copy.secondaryCta[locale]}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">{copy.faqTitle[locale]}</h2>
      <div class="mt-8 space-y-4">
        {copy.generalFaq.map((item, index) => (
          <Accordion
            label={item.question[locale]}
            group={`services-general-${locale}`}
            expanded={index === 0 ? "true" : "false"}
          >
            <p class="text-gray-600 dark:text-gray-300 leading-8">{item.answer[locale]}</p>
          </Accordion>
        ))}
      </div>
    </div>
  </section>
</main>
